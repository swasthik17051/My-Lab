<!-- Global Application Toast notification banner -->
<div class="toast" id="toast"></div>

<script>
// ========================================================
// INITIAL STATE CONFIGURATION
// ========================================================
const CURRENT_USER = 'SM';
const LAB_OPTIONS = [
    "Embossing", "Ski-Tipping", "Adhesive Weight","Bow Results","Bulge","Flatness",
    "Incoming Raw Material","Load Testing","Moisture","Mono Color","Offset",
    "Peel Strength","QC Checks","QC Offline Sample Test","Railing Color Dashboard",
    "Shell Stock","Shell Thickness","Streak Color","Streaker Testing",
    "Strength","Surface Energy","Thickness","TSC","VMM Dimension Dashboard","Width"
];
const EMBOSSING_LOCATIONS = `Embossing (Fernley > Decking)\nEmbossing (Winchester > Decking > Building 1)\nEmbossing (Winchester > Decking > Building 4)\nEmbossing (Winchester > Decking > Building 6)`;
const SKI_TIPPING_LOCATIONS = `FERNLEY > DECKING > SkiTipping\nWINCHESTER > DECKING > Building1 > SkiTipping\nWINCHESTER > DECKING > Building4 > SkiTipping\nWINCHESTER > DECKING > Building6 > SkiTipping`;
const PAGE_SIZE = 100;

const state = {
    permissions: { new: true, edit: true, delete: true },
    configPermissions: { new: true, edit: true, delete: true },
    nextMasterSlNo: 1,
    masterPage: 1,
    masterFilter: [],
    masterNewBatch: new Set(),
    masterList: [],
    labConfigs: {},
    embossingData: [],
    selectedLab: '',
    editingConfigId: null, isCreatingConfig: false,
    newConfigSel: { pl:'', pt:'', p:'', c:'', l:'' },
    configNewBatch: new Set(),
    editingDashId: null, isCreatingDash: true,
    newDashSel: { pl:'', pt:'', p:'', c:'', l:'', line:'' },
    editDashSel: { pl:'', pt:'', p:'', c:'', l:'' },
    spMode: null, spId: null,
    alpFilters: {}, configPage: 1,
    stFilters: {}, stPage: 1,
    editingStId: null, isCreatingStConfig: false,
    newStSel: { pl:'', pt:'', p:'', c:'', l:'' },
    stNewBatch: new Set(),
    stDashData: [], stDashPage: 1, stDashFilters: {},
    isCreatingStDash: true,
    stDashNewSel: { pl:'', pt:'', p:'', c:'', l:'' },
    editingStDashId: null, editStDashSel: {},
    stDashStartDate: '', stDashEndDate: '',
    dashFilters: {}, dashPage: 1, dashStartDate: '', dashEndDate: '',
    columnFilters: {},
    activeQCChart: 'line'
};

// Custom Confirm modal tracking state
let customConfirmCallback = null;

// ========================================================
// NO-ALERT COMPLIANT CUSTOM CONFIRM ENGINE
// ========================================================
function customConfirm(text, onOk) {
    document.getElementById('confirm-modal-text').innerText = text;
    const modal = document.getElementById('custom-confirm-modal');
    modal.classList.add('show');
    customConfirmCallback = onOk;
    
    // Bind action to confirmed button
    const okBtn = document.getElementById('confirm-modal-ok-btn');
    okBtn.onclick = function() {
        closeCustomConfirm(true);
    };
}

function closeCustomConfirm(confirmed) {
    document.getElementById('custom-confirm-modal').classList.remove('show');
    if (confirmed && customConfirmCallback) {
        customConfirmCallback();
    }
    customConfirmCallback = null;
}

// ========================================================
// SEEDING THE MOCK DATA MANIPULATOR
// ========================================================
function seedDeckingPrototypeData() {
    const products = [
