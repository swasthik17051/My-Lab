    const now = getNow();
    
    // 1. Populate Master deck list
    products.forEach((p, index) => {
        const id = 1000 + index;
        state.masterList.push({
            id: id,
            slNo: index + 1,
            prodLine: p.pl,
            type: p.pt,
            profile: p.p,
            color: p.c,
            length: p.l,
            sku: p.sku,
            desc: p.desc,
            status: true,
            createdBy: 'System',
            createdDate: now.full,
            history: [{ date: now.full, action: 'Created', user: 'System', details: 'Initial load' }]
        });
        state.nextMasterSlNo = index + 2;
    });

    // 2. Configure default bounds limits
    state.labConfigs['Embossing'] = [
        { id: 2001, slNo: 1, prodLine: "Transcend", type: "1 x 6", profile: "Grooved", color: "Island Mist", length: "12", sku: "IM010612TG01", desc: "Transcend Grooved 1x6 Board", min: 0.055, max: 0.075, status: true, createdBy: "System", history: [{ date: now.full, action: 'Created', user: 'System', details: 'Initial load' }] },
        { id: 2002, slNo: 2, prodLine: "Transcend", type: "1 x 6", profile: "Grooved", color: "Spiced Rum", length: "16", sku: "SR010616TG01", desc: "Transcend Grooved 1x6 Board", min: 0.052, max: 0.072, status: true, createdBy: "System", history: [{ date: now.full, action: 'Created', user: 'System', details: 'Initial load' }] },
        { id: 2003, slNo: 3, prodLine: "Enhance", type: "1 x 6", profile: "Square Edge", color: "Beach Dune", length: "12", sku: "BD010612EG01", desc: "Enhance Square 1x6 Board", min: 0.045, max: 0.065, status: true, createdBy: "System", history: [{ date: now.full, action: 'Created', user: 'System', details: 'Initial load' }] }
    ];

    state.labConfigs['Ski-Tipping'] = [
        {
            id: 3001, slNo: 1, prodLine: "Transcend", type: "1 x 6", profile: "Grooved", color: "Spiced Rum", length: "16", sku: "SR010616TG01", desc: "Transcend Grooved 1x6 Board",
            stl: 0.12, mhl: 0.08, mhls: 0.09, dml: 12.0, stt: 0.14, mht: 0.07, mhts: 0.08, dmt: 11.5,
            status: true, createdBy: "System", history: [{ date: now.full, action: 'Created', user: 'System', details: 'Initial load' }]
        }
    ];

    // 3. Mock up operational test entries
    const isoDate = getISODate();
    state.embossingData = [
        { id: 4001, date: "15-Jul-2026", time: "09:15", line: "Line A", prodLine: "Transcend", profileType: "1 x 6", profile: "Grooved", color: "Island Mist", length: "12", m1: 0.065, m2: 0.062, m3: 0.068, avg: 0.065, createdBy: "Operator_1", createdOn: isoDate, modifiedOn: null, snapMin: 0.055, snapMax: 0.075, history: [{ date: now.full, action: 'Created', user: 'Operator_1', details: 'Initial Entry' }] },
        { id: 4002, date: "15-Jul-2026", time: "11:30", line: "Line A", prodLine: "Transcend", profileType: "1 x 6", profile: "Grooved", color: "Island Mist", length: "12", m1: 0.058, m2: 0.059, m3: 0.057, avg: 0.058, createdBy: "Operator_1", createdOn: isoDate, modifiedOn: null, snapMin: 0.055, snapMax: 0.075, history: [{ date: now.full, action: 'Created', user: 'Operator_1', details: 'Initial Entry' }] },
        { id: 4003, date: "16-Jul-2026", time: "08:00", line: "Line B", prodLine: "Transcend", profileType: "1 x 6", profile: "Grooved", color: "Spiced Rum", length: "16", m1: 0.053, m2: 0.051, m3: 0.054, avg: 0.0527, createdBy: "Operator_2", createdOn: isoDate, modifiedOn: null, snapMin: 0.052, snapMax: 0.072, history: [{ date: now.full, action: 'Created', user: 'Operator_2', details: 'Initial Entry' }] },
        // Failed Out-of-Spec sample visualization demo
        { id: 4004, date: "16-Jul-2026", time: "14:22", line: "Line A", prodLine: "Transcend", profileType: "1 x 6", profile: "Grooved", color: "Island Mist", length: "12", m1: 0.082, m2: 0.081, m3: 0.080, avg: 0.081, createdBy: "Operator_1", createdOn: isoDate, modifiedOn: null, snapMin: 0.055, snapMax: 0.075, history: [{ date: now.full, action: 'Created', user: 'Operator_1', details: 'Initial Entry (OOS Warning)' }] }
    ];

    state.stDashData = [
        {
            id: 5001, date: "16-Jul-2026", time: "10:45", line: "302", prodLine: "Transcend", profileType: "1 x 6", profile: "Grooved", color: "Spiced Rum", length: "16", sku: "SR010616TG01",
            shiftCode: "A-Day", wo: "WO-9482", bundle: "B-23", board: "BD-08",
            stl: 0.10, mhl: 0.06, mhls: 0.07, dml: 10.2, stt: 0.11, mht: 0.05, mhts: 0.06, dmt: 10.1,
            comment: "Standard run profile", snapStl: 0.12, snapMhl: 0.08, snapMhls: 0.09, snapDml: 12.0, snapStt: 0.14, snapMht: 0.07, snapMhts: 0.08, snapDmt: 11.5,
            createdBy: "Operator_QC", createdOn: isoDate, modifiedOn: null, history: [{ date: now.full, action: 'Created', user: 'Operator_QC', details: 'Initial Entry' }]
        },
        {
            id: 5002, date: "17-Jul-2026", time: "09:12", line: "302", prodLine: "Transcend", profileType: "1 x 6", profile: "Grooved", color: "Spiced Rum", length: "16", sku: "SR010616TG01",
            shiftCode: "B-Night", wo: "WO-9501", bundle: "B-01", board: "BD-02",
            stl: 0.13, mhl: 0.09, mhls: 0.10, dml: 12.5, stt: 0.15, mht: 0.08, mhts: 0.09, dmt: 12.1,
            comment: "Slight high variation observed", snapStl: 0.12, snapMhl: 0.08, snapMhls: 0.09, snapDml: 12.0, snapStt: 0.14, snapMht: 0.07, snapMhts: 0.08, snapDmt: 11.5,
            createdBy: "Operator_QC_2", createdOn: isoDate, modifiedOn: null, history: [{ date: now.full, action: 'Created', user: 'Operator_QC_2', details: 'Initial Entry (OOS Detected)' }]
        }
    ];
}

// ========================================================
// ========================================================
function renderSPCControlChart() {
    const container = document.getElementById('emb-chart-svg-container');
    if (!container) return;

    // Retrieve active filtered dataset
    const data = getFilteredDash().slice(0, 10).reverse(); // Keep recent 10 for clean layout
    
    if (data.length === 0) {
        container.innerHTML = `<span class="emb-chart-hint">No filtered manufacturing metrics found to map chart. Add test logs above.</span>`;
        return;
    }

    const svgWidth = container.clientWidth || 700;
    const svgHeight = 160;
    const padding = 30;
    const graphWidth = svgWidth - (padding * 2);
    const graphHeight = svgHeight - (padding * 2);

    // Get Spec Min / Max limits
    const ucl = data[0].snapMax !== null ? data[0].snapMax : 0.080;
    const lcl = data[0].snapMin !== null ? data[0].snapMin : 0.040;
    const mean = (ucl + lcl) / 2;

    // Define Y-axis bounds dynamically
    const maxVal = Math.max(ucl, ...data.map(d => d.avg)) * 1.1;
    const minVal = Math.min(lcl, ...data.map(d => d.avg)) * 0.9;
    const yRange = maxVal - minVal;

    const getX = (index) => padding + (index * (graphWidth / (Math.max(1, data.length - 1))));
    const getY = (val) => svgHeight - padding - (((val - minVal) / yRange) * graphHeight);

    // Build SVG Elements
    let svgHtml = `<svg width="100%" height="100%" viewBox="0 0 ${svgWidth} ${svgHeight}">`;

    // 1. Plot spec limit lines (UCL & LCL bounds)
    const uclY = getY(ucl);
    const lclY = getY(lcl);
    const meanY = getY(mean);

    // UCL line (Upper Spec limit)
    svgHtml += `<line x1="${padding}" y1="${uclY}" x2="${svgWidth - padding}" y2="${uclY}" stroke="#e53935" stroke-width="1.5" stroke-dasharray="4,4" />`;
    svgHtml += `<text x="${svgWidth - padding + 5}" y="${uclY + 4}" fill="#e53935" font-size="10" font-weight="bold">UCL (${ucl.toFixed(3)})</text>`;

    // LCL line (Lower Spec limit)
    svgHtml += `<line x1="${padding}" y1="${lclY}" x2="${svgWidth - padding}" y2="${lclY}" stroke="#e53935" stroke-width="1.5" stroke-dasharray="4,4" />`;
    svgHtml += `<text x="${svgWidth - padding + 5}" y="${lclY + 4}" fill="#e53935" font-size="10" font-weight="bold">LCL (${lcl.toFixed(3)})</text>`;

    // Mean target line
    svgHtml += `<line x1="${padding}" y1="${meanY}" x2="${svgWidth - padding}" y2="${meanY}" stroke="#4caf50" stroke-width="1" stroke-dasharray="2,2" />`;
    svgHtml += `<text x="${svgWidth - padding + 5}" y="${meanY + 4}" fill="#4caf50" font-size="10">Target (${mean.toFixed(3)})</text>`;

    // 2. Draw quality metric trend lines
    let polyPoints = "";
    data.forEach((d, idx) => {
        polyPoints += `${getX(idx)},${getY(d.avg)} `;
    });
    svgHtml += `<polyline points="${polyPoints}" fill="none" stroke="#2196f3" stroke-width="2" />`;

    // 3. Mark run nodes with pass/fail tooltips
    data.forEach((d, idx) => {
        const x = getX(idx);
        const y = getY(d.avg);
        const inSpec = d.avg >= lcl && d.avg <= ucl;
        const color = inSpec ? "#4caf50" : "#f44336";

        svgHtml += `<circle cx="${x}" cy="${y}" r="4" fill="${color}" stroke="#fff" stroke-width="1" />`;
        svgHtml += `<text x="${x}" y="${y - 8}" fill="#555" font-size="9" text-anchor="middle">${d.avg.toFixed(3)}</text>`;
        svgHtml += `<text x="${x}" y="${svgHeight - 8}" fill="#888" font-size="9" text-anchor="middle">${d.time}</text>`;
    });

    svgHtml += `</svg>`;
    container.innerHTML = svgHtml;
}

function selectQCChart(type) {
    state.activeQCChart = type;
    document.querySelectorAll('.emb-chart-link').forEach(el => el.classList.remove('selected-chart'));
    
    if (type === 'line') document.getElementById('lnk-line-chart').classList.add('selected-chart');
    if (type === 'color') document.getElementById('lnk-color-chart').classList.add('selected-chart');
    if (type === 'profile') document.getElementById('lnk-profile-chart').classList.add('selected-chart');

    renderSPCControlChart();
}

window.addEventListener('resize', renderSPCControlChart);

// ========================================================
// UTILS & TIMING HELPERS
// ========================================================
function getNow() {
    const now = new Date();
    const pad = n => n < 10 ? '0'+n : n;
    const date = `${pad(now.getDate())}-${['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][now.getMonth()]}-${now.getFullYear()}`;
    const time = `${pad(now.getHours())}:${pad(now.getMinutes())}`;
    return { date, time, full: `${date} ${time}` };
}
function getISODate() {
    const now = new Date();
    return `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
}
function showToast(msg, type='') {
    const t = document.getElementById('toast');
    t.innerText = msg; t.className = `toast ${type} show`;
    setTimeout(() => t.className = 'toast', 3200);
}
function downloadCSV(content, filename) {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([content], {type:'text/csv'}));
    a.download = filename;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
}
function handleLogoUpload(e) {
    const file = e.target.files[0];
    if (file) {
        const r = new FileReader();
        r.onload = evt => {
            document.getElementById('logo-area').innerHTML = `<img src="${evt.target.result}" style="max-height: 40px; max-width: 100%;">`;
            showToast('Logo updated successfully', 'success');
        };
        r.readAsDataURL(file);
    }
}
function toggleFullscreen() {
    if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen();
    } else if (document.exitFullscreen) {
        document.exitFullscreen();
    }
}

let openMenuEl = null;
function toggleActionMenu(btn, id) {
    const menu = btn.nextElementSibling;
    if (openMenuEl && openMenuEl !== menu) openMenuEl.classList.remove('show');
    menu.classList.toggle('show');
    openMenuEl = menu.classList.contains('show') ? menu : null;
}
document.addEventListener('click', e => {
    if (!e.target.closest('.action-wrap')) {
        document.querySelectorAll('.action-menu.show').forEach(m => m.classList.remove('show'));
        openMenuEl = null;
    }
});

// ========================================================
// ========================================================
function switchView(viewId, navEl, subEl, titleOverride) {
    document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active-view'));
    document.getElementById(viewId).classList.add('active-view');
    const titleMap = {
        'view-dashboard': 'Plant Dashboard',
        'view-plant-winchester': 'Winchester',
        'view-section-decking': 'Decking',
        'view-buildings': 'Buildings',
        'view-embossing-dashboard': 'Embossing Dashboard',
        'view-st-dashboard': 'SkiTipping Dashboard',
        'view-master-list': 'Master List-Decking',
        'view-assign-lab': 'Assign Lab Properties',
        'view-app-settings': 'Application Settings',
        'view-roles': 'User Management',
        'view-placeholder': titleOverride || 'Library'
    };
    document.getElementById('page-title-display').innerText = titleMap[viewId] || 'Dashboard';
    if (viewId === 'view-placeholder' && titleOverride) document.getElementById('placeholder-title').innerText = titleOverride;
    
    if (viewId === 'view-embossing-dashboard') {
        state.newDashSel = { pl:'', pt:'', p:'', c:'', l:'', line:'' };
        renderDashTable();
        // Delay drawing to allow layout execution to complete for proper dimensions
        setTimeout(renderSPCControlChart, 100);
    }
    if (viewId === 'view-st-dashboard') {
        state.stDashNewSel = { pl:'', pt:'', p:'', c:'', l:'' };
        renderStDashTable();
    }
    if (navEl || subEl) {
        document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.submenu-item, .sub-submenu-item').forEach(el => el.classList.remove('active-sub'));
        if (navEl) navEl.classList.add('active');
        if (subEl) subEl.classList.add('active-sub');
    }
}
function toggleSubmenu(id, navEl) {
    const el = document.getElementById(id);
    const isOpen = el.classList.contains('open');
    el.classList.toggle('open');
    const arrowId = 'arrow-' + id;
    const arrow = document.getElementById(arrowId);
    if (arrow) arrow.classList.toggle('open', !isOpen);
}

// ========================================================
// MASTER MANUFACTURING SPEC LOGISTICS
// ========================================================
let openColFilterDdId = null;

function openColFilter(event, field, iconEl) {
    event.stopPropagation();
    const ddId = 'cfd-' + field;
    const dd = document.getElementById(ddId);
    if (!dd) return;

    if (openColFilterDdId && openColFilterDdId !== ddId) {
        const old = document.getElementById(openColFilterDdId);
        if (old) old.classList.remove('show');
    }

    if (dd.classList.contains('show')) {
        dd.classList.remove('show');
        openColFilterDdId = null;
        return;
    }

    const vals = [...new Set(state.masterList.map(r => {
        if (field === 'status') return r.status ? 'Active' : 'Inactive';
        return String(r[field] || '');
    }))].filter(v => v !== '').sort();

    const current = state.columnFilters[field];
    let html = `<div class="col-filter-item clear-all" onclick="clearColFilter('${field}')"><i class="fas fa-times" style="font-size:10px;"></i> All / Clear</div>`;
    vals.forEach(v => {
        const sel = current === v ? 'selected' : '';
        html += `<div class="col-filter-item ${sel}" onclick="applyColFilter('${field}','${v.replace(/'/g,"\'")}',this)">${v}</div>`;
    });
    dd.innerHTML = html;
    dd.classList.add('show');
    openColFilterDdId = ddId;
}

function applyColFilter(field, value, itemEl) {
    state.columnFilters[field] = value;
    const icon = document.getElementById('fi-' + field);
    if (icon) icon.classList.add('active-filter');
    const dd = document.getElementById('cfd-' + field);
    if (dd) dd.classList.remove('show');
    openColFilterDdId = null;
    state.masterPage = 1;
    renderMasterTable();
}

function clearColFilter(field) {
    delete state.columnFilters[field];
    const icon = document.getElementById('fi-' + field);
    if (icon) icon.classList.remove('active-filter');
    const dd = document.getElementById('cfd-' + field);
    if (dd) dd.classList.remove('show');
    openColFilterDdId = null;
    state.masterPage = 1;
    renderMasterTable();
}

document.addEventListener('click', function(e) {
    if (!e.target.closest('.col-filter-dropdown') && !e.target.classList.contains('col-fi')) {
        document.querySelectorAll('.col-filter-dropdown.show').forEach(d => d.classList.remove('show'));
        openColFilterDdId = null;
    }
});

function getFilteredMaster() {
    return state.masterList.filter(row => {
        return Object.entries(state.columnFilters).every(([field, val]) => {
            if (!val) return true;
            if (field === 'status') return (row.status ? 'Active' : 'Inactive') === val;
            return String(row[field] || '') === val;
        });
    });
}

function renderMasterTable() {
    const tbody = document.getElementById('master-table-body');
    if (!tbody) return;
    const filtered = getFilteredMaster();
    const total = filtered.length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (state.masterPage > totalPages) state.masterPage = totalPages;
    const start = (state.masterPage - 1) * PAGE_SIZE;
    const pageData = filtered.slice(start, start + PAGE_SIZE);

    tbody.innerHTML = '';
    pageData.forEach(row => {
        const isNew = state.masterNewBatch.has(row.id);
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>
                <div class="action-wrap">
                    <button class="three-dot-btn" onclick="toggleActionMenu(this, ${row.id})">&#8942;</button>
                    <div class="action-menu">
                        ${state.permissions.edit ? `<div class="action-item" onclick="openEditPanel(${row.id});this.closest('.action-menu').classList.remove('show')"><i class="fas fa-pencil-alt"></i> Edit</div>` : ''}
                        ${state.permissions.delete ? `<div class="action-item danger" onclick="deleteMaster(${row.id});this.closest('.action-menu').classList.remove('show')"><i class="fas fa-trash"></i> Delete</div>` : ''}
                        <div class="action-item" onclick="openHistPanelMaster(${row.id});this.closest('.action-menu').classList.remove('show')"><i class="fas fa-history"></i> History</div>
                    </div>
                </div>
            </td>
            <td>${row.slNo}${isNew ? ' <span class="badge-new">new</span>' : ''}</td>
            <td>${row.prodLine}</td>
            <td>${row.type}</td>
            <td>${row.profile}</td>
            <td>${row.color}</td>
            <td>${row.length}</td>
            <td>${row.sku}</td>
            <td>${row.desc}</td>
            <td>${row.status ? '<i class="fas fa-check status-check"></i>' : '<i class="fas fa-times status-cross"></i>'}</td>
            <td>${row.createdBy || CURRENT_USER}</td>
            <td style="white-space:nowrap;">${row.createdDate || '—'}</td>
        `;
        tbody.appendChild(tr);
    });

    document.getElementById('master-rec-count').innerText = `${total} Record${total!==1?'s':''}`;

    const pagTop = document.getElementById('master-pagination-top');
    const firstBtn = `<button class="page-btn txt" ${state.masterPage===1?'disabled':''} onclick="gotoMasterPage(1)">First</button>`;
    const prevBtn = `<button class="page-btn" ${state.masterPage===1?'disabled':''} onclick="gotoMasterPage(${state.masterPage-1})">&lsaquo;</button>`;
    let pages = '';
    for (let i = Math.max(1, state.masterPage-2); i <= Math.min(totalPages, state.masterPage+2); i++) {
        pages += `<button class="page-btn ${i===state.masterPage?'active':''}" onclick="gotoMasterPage(${i})">${i}</button>`;
    }
    const nextBtn = `<button class="page-btn" ${state.masterPage===totalPages?'disabled':''} onclick="gotoMasterPage(${state.masterPage+1})">&rsaquo;</button>`;
    const lastBtn = `<button class="page-btn txt" ${state.masterPage===totalPages?'disabled':''} onclick="gotoMasterPage(${totalPages})">Last</button>`;
    pagTop.innerHTML = firstBtn + prevBtn + pages + nextBtn + lastBtn;
}
function gotoMasterPage(p) { state.masterPage = p; renderMasterTable(); }

// Compliance modification: customConfirm replaces blocking window.confirm()
function deleteMaster(id) {
    customConfirm('Are you absolutely sure you want to delete this master product record? This operation cannot be undone.', () => {
        state.masterList = state.masterList.filter(r => r.id !== id);
        state.masterNewBatch.delete(id);
        renderMasterTable();
        showToast('Record deleted from master index', 'success');
    });
}

function openCreatePanel() {
    if (!state.permissions.new) return;
    state.spMode = 'create'; state.spId = null;
    document.getElementById('sp-title').innerText = 'New Master List-Decking';
    document.getElementById('sp-save-btn').innerText = 'Create';
    ['sp-pl','sp-pt','sp-p','sp-c','sp-l','sp-sku','sp-desc'].forEach(id => {
        const el = document.getElementById(id); el.value = ''; el.disabled = false; el.classList.remove('view-only');
    });
    document.getElementById('sp-status-create-row').style.display = 'block';
    document.getElementById('sp-status-edit-row').style.display = 'none';
    showSidePanel();
}
function openEditPanel(id) {
    if (!state.permissions.edit) return;
    const row = state.masterList.find(r => r.id === id);
    if (!row) return;
    state.spMode = 'edit'; state.spId = id;
    document.getElementById('sp-title').innerText = 'Edit Record';
    document.getElementById('sp-save-btn').innerText = 'Update';
    const vals = { 'sp-pl': row.prodLine, 'sp-pt': row.type, 'sp-p': row.profile, 'sp-c': row.color, 'sp-l': row.length, 'sp-sku': row.sku, 'sp-desc': row.desc };
    Object.entries(vals).forEach(([fid, val]) => {
        const el = document.getElementById(fid); el.value = val; el.disabled = true; el.classList.add('view-only');
    });
    document.getElementById('sp-status-create-row').style.display = 'none';
    document.getElementById('sp-status-edit-row').style.display = 'block';
    document.getElementById('sp-edit-status').checked = row.status;
    document.getElementById('sp-edit-status-lbl').innerText = row.status ? 'Active' : 'Inactive';
    showSidePanel();
}
function showSidePanel() {
    document.getElementById('sp-overlay').classList.add('show');
    document.getElementById('master-side-panel').classList.add('open');
}
function closeSidePanel() {
    document.getElementById('sp-overlay').classList.remove('show');
    document.getElementById('master-side-panel').classList.remove('open');
    document.getElementById('hist-side-panel').classList.remove('open');
}
function closeHistPanel() {
    document.getElementById('sp-overlay').classList.remove('show');
    document.getElementById('hist-side-panel').classList.remove('open');
}

// ========================================================
// ========================================================
function saveSidePanel() {
    if (state.spMode === 'create') {
        const pl = document.getElementById('sp-pl').value.trim();
        const pt = document.getElementById('sp-pt').value.trim();
        const p  = document.getElementById('sp-p').value.trim();
        const c  = document.getElementById('sp-c').value.trim();
        const l  = document.getElementById('sp-l').value.trim();
        const sku = document.getElementById('sp-sku').value.trim();
        const desc = document.getElementById('sp-desc').value.trim();
        if (!pl||!pt||!p||!c||!l||!sku||!desc) { showToast('Please enter all required attributes', 'error'); return; }
        const dup = state.masterList.some(r => r.prodLine===pl && r.type===pt && r.profile===p && r.color===c && r.length===l && r.sku===sku);
        if (dup) { showToast('A matching product SKU registration already exists', 'error'); return; }
        const now = getNow();
        const newId = Date.now();
        state.masterNewBatch = new Set([newId]);
        state.masterList.push({
            id: newId, slNo: state.masterList.length + 1,
            prodLine: pl, type: pt, profile: p, color: c, length: l, sku, desc,
            status: true, createdBy: CURRENT_USER, createdDate: now.full,
            history: [{ date: now.full, action: 'Created', user: CURRENT_USER, details: 'Record Created manually' }]
        });
        state.masterPage = 99999;
        renderMasterTable();
        showToast('Decking product catalog updated', 'success');
    } else if (state.spMode === 'edit') {
        const row = state.masterList.find(r => r.id === state.spId);
        const newStatus = document.getElementById('sp-edit-status').checked;
        if (row.status !== newStatus) {
            const now = getNow();
            row.status = newStatus;
            row.history.unshift({ date: now.full, action: 'Updated', user: CURRENT_USER, details: `Status adjusted → ${newStatus?'Active':'Inactive'}` });
        }
        renderMasterTable();
        showToast('Attribute properties updated', 'success');
    }
    closeSidePanel();
}

function openHistPanelMaster(id) {
    const row = state.masterList.find(r => r.id === id);
    if (!row) return;
    const hist = row.history || [];
    const container = document.getElementById('hist-entries');
    if (hist.length === 0) {
        container.innerHTML = '<div style="padding:30px;text-align:center;color:#bbb;"><i class="fas fa-history" style="font-size:30px;margin-bottom:10px;display:block;"></i>No actions logged yet.</div>';
    } else {
        container.innerHTML = hist.map(h => {
            const cls = h.action==='Created'?'hist-created':h.action==='Imported'?'hist-imported':'hist-updated';
            return `<div class="hist-entry">
                <div class="hist-avatar"><i class="fas fa-user"></i></div>
                <div style="flex:1;">
                    <span class="hist-badge ${cls}">${h.action}</span>
                    <table class="hist-table">
                        <tr><th>Operator</th><th>Log Time</th></tr>
                        <tr><td>${h.user}</td><td>${h.date}</td></tr>
                        ${h.details ? `<tr><td colspan="2" style="color:#666;font-size:11px;font-style:italic;">${h.details}</td></tr>` : ''}
                    </table>
                </div>
            </div>`;
        }).join('');
    }
    document.getElementById('sp-overlay').classList.add('show');
    document.getElementById('hist-side-panel').classList.add('open');
}

function openHistPanelConfig(id) {
    const item = (state.labConfigs[state.selectedLab]||[]).find(i=>i.id===id);
    if (!item) return;
    populateHistPanel(item.history||[], `Config: ${item.prodLine} / ${item.color}`);
}
function openHistPanelDash(id) {
    const item = state.embossingData.find(r=>r.id===id);
    if (!item) return;
    populateHistPanel(item.history||[], `Embossing: ${item.prodLine} / ${item.date}`);
}
function populateHistPanel(hist, label) {
    const container = document.getElementById('hist-entries');
    document.querySelector('#hist-side-panel .hist-header h3').innerText = 'Operational History';
    if (hist.length === 0) {
        container.innerHTML = '<div style="padding:30px;text-align:center;color:#bbb;"><i class="fas fa-history" style="font-size:30px;margin-bottom:10px;display:block;"></i>No actions logged yet.</div>';
    } else {
        container.innerHTML = hist.map(h => {
            const cls = h.action==='Created'?'hist-created':h.action==='Imported'?'hist-imported':'hist-updated';
            return `<div class="hist-entry">
                <div class="hist-avatar"><i class="fas fa-user"></i></div>
                <div style="flex:1;">
                    <span class="hist-badge ${cls}">${h.action}</span>
                    <table class="hist-table">
                        <tr><th>Operator</th><th>Log Time</th></tr>
                        <tr><td>${h.user}</td><td>${h.date}</td></tr>
                        ${h.details ? `<tr><td colspan="2" style="color:#666;font-size:11px;font-style:italic;">${h.details}</td></tr>` : ''}
                    </table>
                </div>
            </div>`;
        }).join('');
    }
    document.getElementById('sp-overlay').classList.add('show');
    document.getElementById('hist-side-panel').classList.add('open');
}

// ========================================================
// SPREADSHEETS PARSING & EXPORTING ENGINES
// ========================================================
function downloadAlpEmbossingTemplate() {
    const header = 'Product Line,Profile Type,Profile,Color,Length (ft.),Bundle SKU,Description,Average Min,Average Max';
    downloadCSV(header + '\n', 'ALP_Embossing_Template.csv');
    showToast('Template layout downloaded', 'success');
}

function parseCSVRow(row) {
    const result = [];
    let cur = '', inQuote = false;
    for (let i = 0; i < row.length; i++) {
        const ch = row[i];
        if (ch === '"') {
            inQuote = !inQuote;
        } else if (ch === ',' && !inQuote) {
            result.push(cur.trim());
            cur = '';
        } else {
            cur += ch;
        }
    }
    result.push(cur.trim());
    return result;
}

function importAlpConfig(event) {
    const file = event.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
        const lines = e.target.result.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n').filter(r => r.trim());
        if (lines.length < 2) { showToast('The selected file possesses no data values', 'error'); return; }

        let added = 0, skipped = 0;
        const now = getNow();
        const newIds = [];
        state.configNewBatch = new Set();
        if (!state.labConfigs[state.selectedLab]) state.labConfigs[state.selectedLab] = [];
        const existing = state.labConfigs[state.selectedLab];

        const headerCols = parseCSVRow(lines[0]).map(h => h.toLowerCase().replace(/[^a-z0-9]/g,''));
        const colIdx = {
            pl:   headerCols.findIndex(h => h.includes('productline') || h.includes('product')),
            pt:   headerCols.findIndex(h => h.includes('profiletype') || h === 'type'),
            p:    headerCols.findIndex(h => h === 'profile'),
            c:    headerCols.findIndex(h => h === 'color' || h === 'colour'),
            l:    headerCols.findIndex(h => h.includes('length')),
            sku:  headerCols.findIndex(h => h.includes('sku')),
            desc: headerCols.findIndex(h => h.includes('desc')),
            min:  headerCols.findIndex(h => h.includes('min')),
            max:  headerCols.findIndex(h => h.includes('max')),
        };

        for (let i = 1; i < lines.length; i++) {
            const cols = parseCSVRow(lines[i]);
            const g = idx => (idx >= 0 && idx < cols.length) ? (cols[idx] || '').trim() : '';

            const pl  = g(colIdx.pl);
            const pt  = g(colIdx.pt);
            const p   = g(colIdx.p);
            const c   = g(colIdx.c);
            const l   = g(colIdx.l);
            const minStr = g(colIdx.min);
            const maxStr = g(colIdx.max);

            if (!pl || !pt || !p || !c || !l) { skipped++; continue; }

            const min = parseFloat(minStr);
            const max = parseFloat(maxStr);
            if (isNaN(min) || isNaN(max)) { skipped++; continue; }
            if (min >= max) { skipped++; continue; }

            const norm = s => String(s||'').trim().toLowerCase();
            const match = state.masterList.find(m =>
                m.status &&
                norm(m.prodLine) === norm(pl) &&
                norm(m.type)     === norm(pt) &&
                norm(m.profile)  === norm(p)  &&
                norm(m.color)    === norm(c)  &&
                norm(m.length)   === norm(l)
            );
            if (!match) { skipped++; continue; }

            const dup = existing.find(cfg =>
                norm(cfg.prodLine)===norm(pl) && norm(cfg.type)===norm(pt) &&
                norm(cfg.profile)===norm(p)   && norm(cfg.color)===norm(c) &&
                norm(cfg.length)===norm(l)    && cfg.status
            );
            if (dup) { skipped++; continue; }

            const nid = Date.now() + i;
            newIds.push(nid);
            existing.push({
                id: nid,
                slNo: existing.length + 1,
                prodLine: match.prodLine, type: match.type,
                profile: match.profile,  color: match.color,
                length: match.length,    sku: match.sku, desc: match.desc,
                min, max, status: true,
                createdBy: CURRENT_USER,
                history: [{ date: now.full, action: 'Imported', user: CURRENT_USER, details: 'Bulk Spec limits uploaded' }]
            });
            added++;
        }

        newIds.forEach(id => state.configNewBatch.add(id));
        state.configPage = 1;
        renderConfigTable();
        showToast(`Limits imported. Added: ${added}, Skipped: ${skipped}`, added > 0 ? 'success' : 'error');
        event.target.value = '';
    };
    reader.readAsText(file);
}

function downloadTemplate() {
    downloadCSV('Product Line,Profile Type,Profile,Color,Length (ft.),Bundle SKU,Description', 'Decking_Master_Template.csv');
    showToast('Template layout downloaded', 'success');
}
function exportMasterList() {
    let csv = 'Product Line,Profile Type,Profile,Color,Length (ft.),Bundle SKU,Description,Status\n';
    state.masterList.forEach(r => { csv += `"${r.prodLine}","${r.type}","${r.profile}","${r.color}","${r.length}","${r.sku}","${r.desc}","${r.status?'Active':'Inactive'}"\n`; });
    downloadCSV(csv, 'Decking_Master_Export.csv');
    showToast('Catalog exported', 'success');
}
function importMasterList(event) {
    const file = event.target.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
        const rows = e.target.result.split('\n').filter(r => r.trim());
        let added = 0, skipped = 0;
        const now = getNow();
        const newIds = [];
        state.masterNewBatch = new Set();
        for (let i = 1; i < rows.length; i++) {
            const cols = rows[i].split(',').map(c => c.replace(/"/g,'').trim());
            if (cols.length < 4) continue;
            const [pl, pt, p, c, l, sku, desc] = cols;
            const dup = state.masterList.some(r => r.prodLine===pl&&r.type===pt&&r.profile===p&&r.color===c&&r.length===l);
            if (!dup && pl && pt && p && c) {
                const nid = Date.now() + i;
                newIds.push(nid);
                state.masterList.push({ id:nid, slNo:state.masterList.length+1, prodLine:pl, type:pt, profile:p, color:c, length:l||'', sku:sku||'', desc:desc||'', status:true, createdBy:CURRENT_USER, createdDate:now.full, history:[{date:now.full,action:'Imported',user:CURRENT_USER,details:'Bulk Catalog Import'}] });
                added++;
            } else skipped++;
        }
        newIds.forEach(id => state.masterNewBatch.add(id));
        state.masterPage = 1;
        renderMasterTable();
        showToast(`Import processed. Added: ${added}, Skipped: ${skipped}`, 'success');
        event.target.value = '';
    };
    reader.readAsText(file);
}

// ========================================================
// ========================================================
function exportEmbossingExcel() {
    const filtered = getFilteredDash();
    let csv = 'Date,Time,Line,Product Line,Profile Type,Profile,Color,Length,Measure 1,Measure 2,Measure 3,Average,Created By,Created On,Modified On\n';
    filtered.forEach(r => {
        csv += `"${r.date}","${r.time}","${r.line}","${r.prodLine}","${r.profileType}","${r.profile}","${r.color}","${r.length}",${r.m1},${r.m2},${r.m3},${r.avg},"${r.createdBy}","${r.createdOn||r.date}","${r.modifiedOn||''}"\n`;
    });
    downloadCSV(csv, 'Embossing_Log_Export.csv');
    showToast('Quality logs exported', 'success');
}
function exportConfigTable() {
    const data = state.labConfigs[state.selectedLab] || [];
    let csv = 'Product Line,Profile Type,Profile,Color,Length,Bundle SKU,Description,Min,Max,Status\n';
    data.forEach(r => { csv += `"${r.prodLine}","${r.type}","${r.profile}","${r.color}","${r.length}","${r.sku}","${r.desc}",${r.min},${r.max},"${r.status?'Active':'Inactive'}"\n`; });
    downloadCSV(csv, `${state.selectedLab}_Specifications_Export.csv`);
    showToast('Limit configs exported', 'success');
}

// ========================================================
// ASSIGN LAB OPERATIONAL PROPERTIES
// ========================================================
function handleLabSelection() {
    const val = document.getElementById('lab-selector').value;
    state.selectedLab = val;
    state.editingConfigId = null; state.isCreatingConfig = false;
    state.editingStId = null; state.isCreatingStConfig = false;
    state.newConfigSel = { pl:'', pt:'', p:'', c:'', l:'' };
    state.newStSel = { pl:'', pt:'', p:'', c:'', l:'' };
    const locEl = document.getElementById('affected-locations');
    const cfgSec = document.getElementById('lab-config-section');
    const stSec  = document.getElementById('st-config-section');
    cfgSec.style.display = 'none';
    stSec.style.display  = 'none';
    if (val === 'Embossing') {
        locEl.value = EMBOSSING_LOCATIONS;
        cfgSec.style.display = 'block';
        if (!state.labConfigs[val]) state.labConfigs[val] = [];
        renderConfigTable();
    } else if (val === 'Ski-Tipping') {
        locEl.value = SKI_TIPPING_LOCATIONS;
        stSec.style.display = 'block';
        if (!state.labConfigs[val]) state.labConfigs[val] = [];
        renderStTable();
    } else if (val) {
        locEl.value = 'No specific location/line routing configurations established for this prototype.';
        cfgSec.style.display = 'block';
        if (!state.labConfigs[val]) state.labConfigs[val] = [];
        renderConfigTable();
    } else {
        locEl.value = '';
    }
}

function buildSelect(field, filters, selectedVal, onchange) {
    let source = state.masterList.filter(m => m.status);
    if (filters.pl) source = source.filter(m => m.prodLine === filters.pl);
    if (filters.pt) source = source.filter(m => m.type === filters.pt);
    if (filters.p)  source = source.filter(m => m.profile === filters.p);
    if (filters.c)  source = source.filter(m => m.color === filters.c);
    const fieldMap = { pl:'prodLine', pt:'type', p:'profile', c:'color', l:'length' };
    const key = fieldMap[field];
    const vals = [...new Set(source.map(m => m[key]))].sort();
    let html = `<select class="form-input" style="min-width:90px;" onchange="${onchange}"><option value="">Select</option>`;
    vals.forEach(v => { html += `<option value="${v}" ${v===selectedVal?'selected':''}>${v}</option>`; });
    return html + '</select>';
}

function handleConfigDropdownChange(field, value) {
    const s = state.newConfigSel;
    const order = ['pl','pt','p','c','l'];
    const idx = order.indexOf(field);
    s[field] = value;
    for (let i = idx+1; i < order.length; i++) s[order[i]] = '';
    renderConfigTable();
}

function getFilteredConfig() {
    const data = state.labConfigs[state.selectedLab] || [];
    return data.filter(item => {
        return Object.entries(state.alpFilters).every(([field, val]) => {
            if (!val) return true;
            if (field === 'status') return (item.status ? 'Active' : 'Inactive') === val;
            return String(item[field] || '') === val;
        });
    });
}

let openAlpFilterId = null;
function openAlpFilter(event, field, iconEl) {
    event.stopPropagation();
    const ddId = 'alp-cfd-' + field;
    const dd = document.getElementById(ddId);
    if (!dd) return;
    if (openAlpFilterId && openAlpFilterId !== ddId) {
        const old = document.getElementById(openAlpFilterId);
        if (old) old.classList.remove('show');
    }
    if (dd.classList.contains('show')) {
        dd.classList.remove('show');
        openAlpFilterId = null;
        return;
    }
    const data = state.labConfigs[state.selectedLab] || [];
    const vals = [...new Set(data.map(r => {
        if (field === 'status') return r.status ? 'Active' : 'Inactive';
        return String(r[field] || '');
    }))].filter(v => v !== '').sort();
    const current = state.alpFilters[field];
    let ddHtml = `<div class="col-filter-item clear-all" onclick="clearAlpFilter('${field}')"><i class="fas fa-times" style="font-size:10px;"></i> All / Clear</div>`;
    vals.forEach(v => {
        const sel = current === v ? 'selected' : '';
        ddHtml += `<div class="col-filter-item ${sel}" onclick="applyAlpFilter('${field}','${v.replace(/'/g,"\'")}',this)">${v}</div>`;
    });
    dd.innerHTML = ddHtml;
    dd.classList.add('show');
    openAlpFilterId = ddId;
}
function applyAlpFilter(field, value) {
    state.alpFilters[field] = value;
    const icon = document.getElementById('alp-fi-' + field);
    if (icon) icon.classList.add('active-filter');
    const dd = document.getElementById('alp-cfd-' + field);
    if (dd) dd.classList.remove('show');
    openAlpFilterId = null;
    state.configPage = 1;
    renderConfigTable();
}
function clearAlpFilter(field) {
    delete state.alpFilters[field];
    const icon = document.getElementById('alp-fi-' + field);
    if (icon) icon.classList.remove('active-filter');
    const dd = document.getElementById('alp-cfd-' + field);
    if (dd) dd.classList.remove('show');
    openAlpFilterId = null;
    state.configPage = 1;
    renderConfigTable();
}
document.addEventListener('click', function(e) {
    if (!e.target.closest('.col-filter-dropdown') && !e.target.classList.contains('col-fi')) {
        document.querySelectorAll('[id^="alp-cfd-"].show').forEach(d => d.classList.remove('show'));
        openAlpFilterId = null;
    }
});

// ========================================================
// ========================================================
function renderConfigTable() {
    const tbody = document.getElementById('config-table-body');
    if (!tbody) return;
    tbody.innerHTML = '';
    const filtered = getFilteredConfig();
    const filteredTotal = filtered.length;
    const totalPages = Math.max(1, Math.ceil(filteredTotal / PAGE_SIZE));
    if (state.configPage > totalPages) state.configPage = totalPages;
    const start = (state.configPage - 1) * PAGE_SIZE;
    const pageData = filtered.slice(start, start + PAGE_SIZE);

    if (state.isCreatingConfig) {
        const s = state.newConfigSel;
        const match = (s.pl&&s.pt&&s.p&&s.c&&s.l) ? state.masterList.find(m => m.status&&m.prodLine===s.pl&&m.type===s.pt&&m.profile===s.p&&m.color===s.c&&m.length===s.l) : null;
        const autoSku = match ? match.sku : '';
        const autoDesc = match ? match.desc : '';
        const tr = document.createElement('tr');
        tr.className = 'new-row-tr';
        tr.innerHTML = `
            <td>
                <button class="btn-icon-only" title="Save" onclick="saveNewConfig()" style="color:white;font-size:16px;"><i class="fas fa-check"></i></button>
                <button class="btn-icon-only" title="Cancel" onclick="cancelConfig()" style="color:white;font-size:16px;"><i class="fas fa-times"></i></button>
            </td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;">Auto</td>
            <td>${buildSelect('pl',{},s.pl,"handleConfigDropdownChange('pl',this.value)")}</td>
            <td>${buildSelect('pt',{pl:s.pl},s.pt,"handleConfigDropdownChange('pt',this.value)")}</td>
            <td>${buildSelect('p',{pl:s.pl,pt:s.pt},s.p,"handleConfigDropdownChange('p',this.value)")}</td>
            <td>${buildSelect('c',{pl:s.pl,pt:s.pt,p:s.p},s.c,"handleConfigDropdownChange('c',this.value)")}</td>
            <td>${buildSelect('l',{pl:s.pl,pt:s.pt,p:s.p,c:s.c},s.l,"handleConfigDropdownChange('l',this.value)")}</td>
            <td><input class="form-input" id="new-cfg-sku" value="${autoSku}" readonly placeholder="Auto-fill"></td>
            <td><input class="form-input" id="new-cfg-desc" value="${autoDesc}" readonly placeholder="Auto-fill"></td>
            <td><input type="number" class="form-input" id="new-cfg-min" placeholder="Min" style="width:60px;"></td>
            <td><input type="number" class="form-input" id="new-cfg-max" placeholder="Max" style="width:60px;"></td>
            <td><span style="color:rgba(255,255,255,0.85);font-size:11px;">Active</span></td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;">${CURRENT_USER}</td>
        `;
        tbody.appendChild(tr);
    }

    pageData.forEach(item => {
        const isEditing = state.editingConfigId === item.id;
        const isNew = state.configNewBatch.has(item.id);
        const tr = document.createElement('tr');
        if (isEditing) tr.className = 'edit-row-tr';
        if (isEditing) {
            tr.innerHTML = `
                <td>
                    <button class="btn-icon-only" title="Save" onclick="saveConfig(${item.id})"><i class="fas fa-check" style="color:var(--success-color)"></i></button>
                    <button class="btn-icon-only" title="Cancel" onclick="cancelConfig()"><i class="fas fa-times"></i></button>
                </td>
                <td>${item.slNo}</td>
                <td><input class="form-input" value="${item.prodLine}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.type}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.profile}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.color}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.length}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.sku}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.desc}" disabled style="background:#f5f5f5;"></td>
                <td><input type="number" class="form-input" id="cfg-min-${item.id}" value="${item.min}" style="width:60px;"></td>
                <td><input type="number" class="form-input" id="cfg-max-${item.id}" value="${item.max}" style="width:60px;"></td>
                <td><label class="switch"><input type="checkbox" id="cfg-status-${item.id}" ${item.status?'checked':''}><span class="slider"></span></label></td>
                <td>${item.createdBy || 'Admin'}</td>
            `;
        } else {
            const masterRec = state.masterList.find(m =>
                m.prodLine === item.prodLine && m.type === item.type &&
                m.profile === item.profile && m.color === item.color && m.length === item.length
            );
            const masterInactive = masterRec && !masterRec.status;
            const cautionHtml = masterInactive
                ? `<span class="caution-wrap">
                     <i class="fas fa-exclamation-triangle caution-icon"></i>
                     <span class="caution-tooltip">Make active in Master Catalog</span>
                   </span>`
                : '';
            const editBtnHtml = state.configPermissions.edit
                ? (masterInactive
                    ? `<span class="edit-disabled-wrap">
                         <button class="btn-icon-only" style="color:#ccc;cursor:not-allowed;" disabled>
                           <i class="fas fa-pencil-alt"></i>
                         </button>
                         <span class="caution-tooltip">Make active in Master Catalog</span>
                       </span>`
                    : `<button class="btn-icon-only" title="Edit" onclick="startEditConfig(${item.id})"><i class="fas fa-pencil-alt"></i></button>`)
                : '';
            tr.innerHTML = `
                <td>
                    ${editBtnHtml}
                    <button class="btn-icon-only" title="History" onclick="openHistPanelConfig(${item.id})"><i class="fas fa-history"></i></button>
                </td>
                <td>${item.slNo}${isNew?' <span class="badge-new">new</span>':''}${cautionHtml}</td>
                <td>${item.prodLine}</td>
                <td>${item.type}</td>
                <td>${item.profile}</td>
                <td>${item.color}</td>
                <td>${item.length}</td>
                <td>${item.sku}</td>
                <td>${item.desc}</td>
                <td>${item.min}</td>
                <td>${item.max}</td>
                <td><span class="status-badge ${item.status?'status-active':'status-inactive'}">${item.status?'Active':'Inactive'}</span></td>
                <td>${item.createdBy || 'Admin'}</td>
            `;
        }
        tbody.appendChild(tr);
    });

    const recEl = document.getElementById('alp-rec-count');
    if (recEl) recEl.innerText = `${filteredTotal} Record${filteredTotal!==1?'s':''}`;
    const pagEl = document.getElementById('alp-pagination');
    if (pagEl) {
        const firstBtn = `<button class="page-btn txt" ${state.configPage===1?'disabled':''} onclick="gotoConfigPage(1)">First</button>`;
        const prevBtn  = `<button class="page-btn" ${state.configPage===1?'disabled':''} onclick="gotoConfigPage(${state.configPage-1})">&lsaquo;</button>`;
        let pages = '';
        for (let i = Math.max(1,state.configPage-2); i <= Math.min(totalPages,state.configPage+2); i++) {
            pages += `<button class="page-btn ${i===state.configPage?'active':''}" onclick="gotoConfigPage(${i})">${i}</button>`;
        }
        const nextBtn = `<button class="page-btn" ${state.configPage===totalPages?'disabled':''} onclick="gotoConfigPage(${state.configPage+1})">&rsaquo;</button>`;
        const lastBtn = `<button class="page-btn txt" ${state.configPage===totalPages?'disabled':''} onclick="gotoConfigPage(${totalPages})">Last</button>`;
        pagEl.innerHTML = firstBtn + prevBtn + pages + nextBtn + lastBtn;
    }
}
function gotoConfigPage(p) { state.configPage = p; renderConfigTable(); }
function startAddNewConfig() {
    state.editingConfigId = null; state.isCreatingConfig = true;
    state.newConfigSel = { pl:'', pt:'', p:'', c:'', l:'' };
    renderConfigTable();
}
function cancelConfig() { state.isCreatingConfig = false; state.editingConfigId = null; renderConfigTable(); }
function startEditConfig(id) { state.isCreatingConfig = false; state.editingConfigId = id; renderConfigTable(); }

function saveNewConfig() {
    const s = state.newConfigSel;
    const min = document.getElementById('new-cfg-min').value;
    const max = document.getElementById('new-cfg-max').value;
    if (!s.pl||!s.pt||!s.p||!s.c||!s.l) { showToast('Complete all product parameters', 'error'); return; }
    if (!min||!max) { showToast('Average bounds limits required', 'error'); return; }
    if (parseFloat(min) >= parseFloat(max)) { showToast('Min bound must be less than Max bound', 'error'); return; }
    const match = state.masterList.find(m => m.status&&m.prodLine===s.pl&&m.type===s.pt&&m.profile===s.p&&m.color===s.c&&m.length===s.l);
    if (!match) { showToast('No matching active master product found', 'error'); return; }
    const dup = (state.labConfigs[state.selectedLab]||[]).find(c => c.prodLine===s.pl&&c.type===s.pt&&c.profile===s.p&&c.color===s.c&&c.length===s.l&&c.status);
    if (dup) { showToast('An active specification configuration already exists for this decking type', 'error'); return; }
    const now = getNow();
    const newId = Date.now();
    state.configNewBatch = new Set([newId]);
    state.labConfigs[state.selectedLab].push({ id:newId, slNo: (state.labConfigs[state.selectedLab]||[]).length + 1, prodLine:match.prodLine, type:match.type, profile:match.profile, color:match.color, length:match.length, sku:match.sku, desc:match.desc, min:parseFloat(min), max:parseFloat(max), status:true, createdBy:CURRENT_USER, history:[{date:now.full,action:'Created',user:CURRENT_USER,details:'Spec Target Bounds set'}] });
    state.isCreatingConfig = false;
    renderConfigTable();
    showToast('Embossing quality targets established', 'success');
}
function saveConfig(id) {
    const rec = state.labConfigs[state.selectedLab].find(i => i.id===id);
    const min = document.getElementById(`cfg-min-${id}`).value;
    const max = document.getElementById(`cfg-max-${id}`).value;
    if (!min||!max) { showToast('Measurement bounds parameters required', 'error'); return; }
    if (parseFloat(min) >= parseFloat(max)) { showToast('Min limit must run lower than Max limit', 'error'); return; }
    const nowStatus = document.getElementById(`cfg-status-${id}`).checked;
    const now = getNow();
    rec.min = parseFloat(min); rec.max = parseFloat(max); rec.status = nowStatus;
    rec.history.unshift({ date:now.full, action:'Updated', user:CURRENT_USER, details: `Bounds modified. Min: ${min}, Max: ${max}, Active Status: ${nowStatus}` });
    state.editingConfigId = null;
    renderConfigTable();
    showToast('Quality limits updated', 'success');
}

// ========================================================
// SKI-TIPPING SPEC LOGISTICS
// ========================================================
function getFilteredSt() {
    const data = state.labConfigs['Ski-Tipping'] || [];
    return data.filter(item =>
        Object.entries(state.stFilters).every(([field, val]) => {
            if (!val) return true;
            if (field === 'status') return (item.status ? 'Active' : 'Inactive') === val;
            return String(item[field] || '') === val;
        })
    );
}
let openStFilterId = null;
function openStFilter(event, field, iconEl) {
    event.stopPropagation();
    const ddId = 'st-cfd-' + field;
    const dd = document.getElementById(ddId);
    if (!dd) return;
    if (openStFilterId && openStFilterId !== ddId) {
        const old = document.getElementById(openStFilterId);
        if (old) old.classList.remove('show');
    }
    if (dd.classList.contains('show')) { dd.classList.remove('show'); openStFilterId = null; return; }
    const data = state.labConfigs['Ski-Tipping'] || [];
    const vals = [...new Set(data.map(r => field === 'status' ? (r.status ? 'Active' : 'Inactive') : String(r[field]||'')))].filter(v=>v!=='').sort();
    const current = state.stFilters[field];
    let ddHtml = `<div class="col-filter-item clear-all" onclick="clearStFilter('${field}')"><i class="fas fa-times" style="font-size:10px;"></i> All / Clear</div>`;
    vals.forEach(v => { ddHtml += `<div class="col-filter-item ${current===v?'selected':''}" onclick="applyStFilter('${field}','${v.replace(/'/g,"\'")}' )">${v}</div>`; });
    dd.innerHTML = ddHtml; dd.classList.add('show'); openStFilterId = ddId;
}
function applyStFilter(field, value) {
    state.stFilters[field] = value;
    const icon = document.getElementById('st-fi-' + field);
    if (icon) icon.classList.add('active-filter');
    const dd = document.getElementById('st-cfd-' + field);
    if (dd) dd.classList.remove('show');
    openStFilterId = null; state.stPage = 1; renderStTable();
}
function clearStFilter(field) {
    delete state.stFilters[field];
    const icon = document.getElementById('st-fi-' + field);
    if (icon) icon.classList.remove('active-filter');
    const dd = document.getElementById('st-cfd-' + field);
    if (dd) dd.classList.remove('show');
    openStFilterId = null; state.stPage = 1; renderStTable();
}
function gotoStPage(p) { state.stPage = p; renderStTable(); }

// ========================================================
// ========================================================
function renderStTable() {
    const tbody = document.getElementById('st-table-body');
    if (!tbody) return;
    tbody.innerHTML = '';
    const filtered = getFilteredSt();
    const filteredTotal = filtered.length;
    const totalPages = Math.max(1, Math.ceil(filteredTotal / PAGE_SIZE));
    if (state.stPage > totalPages) state.stPage = totalPages;
    const start = (state.stPage - 1) * PAGE_SIZE;
    const pageData = filtered.slice(start, start + PAGE_SIZE);

    if (state.isCreatingStConfig) {
        const s = state.newStSel;
        const match = (s.pl&&s.pt&&s.p&&s.c&&s.l) ? state.masterList.find(m => m.status&&m.prodLine===s.pl&&m.type===s.pt&&m.profile===s.p&&m.color===s.c&&m.length===s.l) : null;
        const autoSku = match ? match.sku : '';
        const autoDesc = match ? match.desc : '';
        const tr = document.createElement('tr');
        tr.className = 'new-row-tr';
        tr.innerHTML = `
            <td>
                <button class="btn-icon-only" title="Save" onclick="saveNewStConfig()" style="color:white;font-size:16px;"><i class="fas fa-check"></i></button>
                <button class="btn-icon-only" title="Cancel" onclick="cancelStConfig()" style="color:white;font-size:16px;"><i class="fas fa-times"></i></button>
            </td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;">Auto</td>
            <td>${buildSelect('pl',{},s.pl,"handleStDropdownChange('pl',this.value)")}</td>
            <td>${buildSelect('pt',{pl:s.pl},s.pt,"handleStDropdownChange('pt',this.value)")}</td>
            <td>${buildSelect('p',{pl:s.pl,pt:s.pt},s.p,"handleStDropdownChange('p',this.value)")}</td>
            <td>${buildSelect('c',{pl:s.pl,pt:s.pt,p:s.p},s.c,"handleStDropdownChange('c',this.value)")}</td>
            <td>${buildSelect('l',{pl:s.pl,pt:s.pt,p:s.p,c:s.c},s.l,"handleStDropdownChange('l',this.value)")}</td>
            <td><input class="form-input" id="new-st-sku" value="${autoSku}" readonly placeholder="Auto-fill"></td>
            <td><input class="form-input" id="new-st-desc" value="${autoDesc}" readonly placeholder="Auto-fill"></td>
            <td style="border-left:2px solid rgba(255,255,255,0.3);"><input type="number" class="form-input" id="new-st-stl" placeholder="Value" style="width:70px;"></td>
            <td><input type="number" class="form-input" id="new-st-mhl" placeholder="Value" style="width:70px;"></td>
            <td style="border-left:1px solid rgba(255,255,255,0.2);"><input type="number" class="form-input" id="new-st-mhls" placeholder="Value" style="width:70px;"></td>
            <td><input type="number" class="form-input" id="new-st-dml" placeholder="Value" style="width:80px;"></td>
            <td style="border-left:2px solid rgba(255,255,255,0.3);"><input type="number" class="form-input" id="new-st-stt" placeholder="Value" style="width:70px;"></td>
            <td><input type="number" class="form-input" id="new-st-mht" placeholder="Value" style="width:70px;"></td>
            <td style="border-left:1px solid rgba(255,255,255,0.2);"><input type="number" class="form-input" id="new-st-mhts" placeholder="Value" style="width:70px;"></td>
            <td><input type="number" class="form-input" id="new-st-dmt" placeholder="Value" style="width:80px;"></td>
            <td><span style="color:rgba(255,255,255,0.85);font-size:11px;">Active</span></td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;">${CURRENT_USER}</td>
        `;
        tbody.appendChild(tr);
    }

    pageData.forEach(item => {
        const isEditing = state.editingStId === item.id;
        const isNew = state.stNewBatch.has(item.id);
        const masterRec = state.masterList.find(m => m.prodLine===item.prodLine && m.type===item.type && m.profile===item.profile && m.color===item.color && m.length===item.length);
        const masterInactive = masterRec && !masterRec.status;
        const cautionHtml = masterInactive ? `<span class="caution-wrap"><i class="fas fa-exclamation-triangle caution-icon"></i><span class="caution-tooltip">Make active in Master Catalog</span></span>` : '';
        const tr = document.createElement('tr');
        if (isEditing) tr.className = 'edit-row-tr';
        if (isEditing) {
            tr.innerHTML = `
                <td>
                    <button class="btn-icon-only" title="Save" onclick="saveStConfig(${item.id})"><i class="fas fa-check" style="color:var(--success-color)"></i></button>
                    <button class="btn-icon-only" title="Cancel" onclick="cancelStConfig()"><i class="fas fa-times"></i></button>
                </td>
                <td>${item.slNo}</td>
                <td><input class="form-input" value="${item.prodLine}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.type}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.profile}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.color}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.length}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.sku}" disabled style="background:#f5f5f5;"></td>
                <td><input class="form-input" value="${item.desc}" disabled style="background:#f5f5f5;"></td>
                <td style="border-left:2px solid #e0e0e0;"><input type="number" class="form-input" id="ed-st-stl" value="${item.stl}" style="width:70px;"></td>
                <td><input type="number" class="form-input" id="ed-st-mhl" value="${item.mhl}" style="width:70px;"></td>
                <td style="border-left:1px solid #eee;"><input type="number" class="form-input" id="ed-st-mhls" value="${item.mhls}" style="width:70px;"></td>
                <td><input type="number" class="form-input" id="ed-st-dml" value="${item.dml}" style="width:80px;"></td>
                <td style="border-left:2px solid #e0e0e0;"><input type="number" class="form-input" id="ed-st-stt" value="${item.stt}" style="width:70px;"></td>
                <td><input type="number" class="form-input" id="ed-st-mht" value="${item.mht}" style="width:70px;"></td>
                <td style="border-left:1px solid #eee;"><input type="number" class="form-input" id="ed-st-mhts" value="${item.mhts}" style="width:70px;"></td>
                <td><input type="number" class="form-input" id="ed-st-dmt" value="${item.dmt}" style="width:80px;"></td>
                <td><label class="switch"><input type="checkbox" id="ed-st-status" ${item.status?'checked':''}><span class="slider"></span></label></td>
                <td>${item.createdBy||CURRENT_USER}</td>
            `;
        } else {
            const editBtnHtml = masterInactive
                ? `<span class="edit-disabled-wrap"><button class="btn-icon-only" style="color:#ccc;cursor:not-allowed;" disabled><i class="fas fa-pencil-alt"></i></button><span class="caution-tooltip">Make active in Master Catalog</span></span>`
                : `<button class="btn-icon-only" title="Edit" onclick="startEditStConfig(${item.id})"><i class="fas fa-pencil-alt"></i></button>`;
            tr.innerHTML = `
                <td>
                    ${editBtnHtml}
                    <button class="btn-icon-only" title="History" onclick="openHistPanelStConfig(${item.id})"><i class="fas fa-history"></i></button>
                </td>
                <td>${item.slNo}${isNew?' <span class="badge-new">new</span>':''}${cautionHtml}</td>
                <td>${item.prodLine}</td>
                <td>${item.type}</td>
                <td>${item.profile}</td>
                <td>${item.color}</td>
                <td>${item.length}</td>
                <td>${item.sku}</td>
                <td>${item.desc}</td>
                <td style="border-left:2px solid #e0e0e0;">${item.stl}</td>
                <td>${item.mhl}</td>
                <td style="border-left:1px solid #eee;">${item.mhls}</td>
                <td>${item.dml}</td>
                <td style="border-left:2px solid #e0e0e0;">${item.stt}</td>
                <td>${item.mht}</td>
                <td style="border-left:1px solid #eee;">${item.mhts}</td>
                <td>${item.dmt}</td>
                <td><span class="status-badge ${item.status?'status-active':'status-inactive'}">${item.status?'Active':'Inactive'}</span></td>
                <td>${item.createdBy||CURRENT_USER}</td>
            `;
        }
        tbody.appendChild(tr);
    });

    const recEl = document.getElementById('st-rec-count');
    if (recEl) recEl.innerText = `${filteredTotal} Record${filteredTotal!==1?'s':''}`;
    const pagEl = document.getElementById('st-pagination');
    if (pagEl) {
        const firstBtn = `<button class="page-btn txt" ${state.stPage===1?'disabled':''} onclick="gotoStPage(1)">First</button>`;
        const prevBtn  = `<button class="page-btn" ${state.stPage===1?'disabled':''} onclick="gotoStPage(${state.stPage-1})">&lsaquo;</button>`;
        let pages = '';
        for (let i = Math.max(1,state.stPage-2); i <= Math.min(totalPages,state.stPage+2); i++) {
            pages += `<button class="page-btn ${i===state.stPage?'active':''}" onclick="gotoStPage(${i})">${i}</button>`;
        }
        const nextBtn = `<button class="page-btn" ${state.stPage===totalPages?'disabled':''} onclick="gotoStPage(${state.stPage+1})">&rsaquo;</button>`;
        const lastBtn = `<button class="page-btn txt" ${state.stPage===totalPages?'disabled':''} onclick="gotoStPage(${totalPages})">Last</button>`;
        pagEl.innerHTML = firstBtn + prevBtn + pages + nextBtn + lastBtn;
    }
}

function handleStDropdownChange(field, value) {
    const s = state.newStSel;
    const order = ['pl','pt','p','c','l'];
    const idx = order.indexOf(field);
    s[field] = value;
    for (let i = idx+1; i < order.length; i++) s[order[i]] = '';
    renderStTable();
}
function startAddNewStConfig() {
    state.editingStId = null; state.isCreatingStConfig = true;
    state.newStSel = { pl:'', pt:'', p:'', c:'', l:'' };
    renderStTable();
}
function cancelStConfig() { state.isCreatingStConfig = false; state.editingStId = null; renderStTable(); }
function startEditStConfig(id) { state.isCreatingStConfig = false; state.editingStId = id; renderStTable(); }

function saveNewStConfig() {
    const s = state.newStSel;
    if (!s.pl||!s.pt||!s.p||!s.c||!s.l) { showToast('Please select all decking parameters', 'error'); return; }
    const fields = ['stl','mhl','mhls','dml','stt','mht','mhts','dmt'];
    const vals = {};
    for (const f of fields) {
        const v = document.getElementById('new-st-'+f)?.value;
        if (!v && v !== '0') { showToast('Complete all specification inputs', 'error'); return; }
        vals[f] = parseFloat(v);
        if (isNaN(vals[f])) { showToast('Numeric values required for all fields', 'error'); return; }
    }
    const match = state.masterList.find(m => m.status&&m.prodLine===s.pl&&m.type===s.pt&&m.profile===s.p&&m.color===s.c&&m.length===s.l);
    if (!match) { showToast('Active product catalog match not found', 'error'); return; }
    const existing = state.labConfigs['Ski-Tipping'] || [];
    const dup = existing.find(c => c.prodLine===s.pl&&c.type===s.pt&&c.profile===s.p&&c.color===s.c&&c.length===s.l&&c.status);
    if (dup) { showToast('An active configuration limits table exists for this decking board profile', 'error'); return; }
    const now = getNow();
    const newId = Date.now();
    state.stNewBatch = new Set([newId]);
    if (!state.labConfigs['Ski-Tipping']) state.labConfigs['Ski-Tipping'] = [];
    state.labConfigs['Ski-Tipping'].push({
        id:newId, slNo: state.labConfigs['Ski-Tipping'].length+1,
        prodLine:match.prodLine, type:match.type, profile:match.profile,
        color:match.color, length:match.length, sku:match.sku, desc:match.desc,
        ...vals, status:true, createdBy:CURRENT_USER,
        history:[{date:now.full, action:'Created', user:CURRENT_USER, details:'Ski-Tipping Limits initialized'}]
    });
    state.isCreatingStConfig = false;
    renderStTable();
    showToast('Ski-Tipping limits saved successfully', 'success');
}

function saveStConfig(id) {
    const rec = state.labConfigs['Ski-Tipping'].find(i => i.id===id);
    const fields = ['stl','mhl','mhls','dml','stt','mht','mhts','dmt'];
    const vals = {};
    for (const f of fields) {
        const v = document.getElementById('ed-st-'+f)?.value;
        if (!v && v !== '0') { showToast('All values must be filled', 'error'); return; }
        vals[f] = parseFloat(v);
        if (isNaN(vals[f])) { showToast('Numeric parameters required', 'error'); return; }
    }
    const nowStatus = document.getElementById('ed-st-status').checked;
    const now = getNow();
    Object.assign(rec, vals, {status:nowStatus});
    rec.history.unshift({date:now.full, action:'Updated', user:CURRENT_USER, details:`Measurements modified. Status active: ${nowStatus}`});
    state.editingStId = null;
    renderStTable();
    showToast('Ski-Tipping parameters saved', 'success');
}

function openHistPanelStConfig(id) {
    const item = (state.labConfigs['Ski-Tipping']||[]).find(i=>i.id===id);
    if (!item) return;
    populateHistPanel(item.history||[], `Ski-Tipping: ${item.prodLine}/${item.color}`);
}

function downloadStTemplate() {
    const header = 'Product Line,Profile Type,Profile,Color,Length (ft.),Bundle SKU,Description,Ski-Tipping(L),Max Hump CSD(L),Max Hump SSD(L),Distance Max Hump to End of Board(L),Ski-Tipping(T),Max Hump CSD(T),Max Hump SSD(T),Distance Max Hump to End of Board(T)';
    downloadCSV(header + '\n', 'ALP_SkiTipping_Template.csv');
    showToast('Template layout downloaded', 'success');
}

function exportStTable() {
    const data = state.labConfigs['Ski-Tipping'] || [];
    let csv = 'Product Line,Profile Type,Profile,Color,Length,Bundle SKU,Description,Ski-Tipping(L),Max Hump CSD(L),Max Hump SSD(L),Dist End Board(L),Ski-Tipping(T),Max Hump CSD(T),Max Hump SSD(T),Dist End Board(T),Status\n';
    data.forEach(r => { csv += `"${r.prodLine}","${r.type}","${r.profile}","${r.color}","${r.length}","${r.sku}","${r.desc}",${r.stl},${r.mhl},${r.mhls},${r.dml},${r.stt},${r.mht},${r.mhts},${r.dmt},"${r.status?'Active':'Inactive'}"\n`; });
    downloadCSV(csv, 'SkiTipping_Limits_Export.csv');
    showToast('Ski-Tipping limit values exported', 'success');
}

// ========================================================
// ========================================================
function importStConfig(event) {
    const file = event.target.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
        const lines = e.target.result.replace(/\r\n/g,'\n').replace(/\r/g,'\n').split('\n').filter(r=>r.trim());
        if (lines.length < 2) { showToast('File has no entries', 'error'); return; }
        let added=0, skipped=0;
        const now = getNow();
        const newIds = [];
        state.stNewBatch = new Set();
        if (!state.labConfigs['Ski-Tipping']) state.labConfigs['Ski-Tipping'] = [];
        const existing = state.labConfigs['Ski-Tipping'];

        const norm    = s => String(s||'').trim().toLowerCase();
        const normHdr = s => s.toLowerCase().replace(/[^a-z0-9]/g, '');

        const rawHeaders = parseCSVRow(lines[0]).map(normHdr);

        const findOrFallback = (fallback, ...patterns) => {
            for (const pat of patterns) {
                const idx = rawHeaders.findIndex(h => h.includes(pat));
                if (idx >= 0) return idx;
            }
            return fallback;
        };

        const ci = {
            pl:   findOrFallback(0,  'productline'),
            pt:   findOrFallback(1,  'profiletype'),
            p:    rawHeaders.indexOf('profile') >= 0 ? rawHeaders.indexOf('profile') : 2,
            c:    findOrFallback(3,  'color', 'colour'),
            l:    findOrFallback(4,  'length'),
            stl:  findOrFallback(7,  'skitippingl'),
            mhl:  findOrFallback(8,  'maxhumpcsdl'),
            mhls: findOrFallback(9,  'maxhumpssdl'),
            dml:  findOrFallback(10, 'distancemaxhumptoendofboardl', 'toendofboardl', 'endofboardl'),
            stt:  findOrFallback(11, 'skitippingt'),
            mht:  findOrFallback(12, 'maxhumpcsdt', 'maxhumpcsdt'), 
            mhts: findOrFallback(13, 'maxhumpssdt', 'maxhumpssdt'),
            dmt:  findOrFallback(14, 'distancemaxhumptoendofboardt', 'toendofboardt', 'endofboardt'),
        };

        const g = (cols, idx) => (idx >= 0 && idx < cols.length) ? (cols[idx]||'').trim() : '';

        for (let i = 1; i < lines.length; i++) {
            const cols = parseCSVRow(lines[i]);
            const pl=g(cols,ci.pl), pt=g(cols,ci.pt), p=g(cols,ci.p), c=g(cols,ci.c), l=g(cols,ci.l);
            if (!pl||!pt||!p||!c||!l) { skipped++; continue; }

            const numMap = { stl:ci.stl, mhl:ci.mhl, mhls:ci.mhls, dml:ci.dml, stt:ci.stt, mht:ci.mht, mhts:ci.mhts, dmt:ci.dmt };
            const nums = {};
            let valid = true;
            for (const [f, idx] of Object.entries(numMap)) {
                const raw = g(cols, idx);
                const v = parseFloat(raw);
                if (isNaN(v)) { valid=false; break; }
                nums[f] = v;
            }
            if (!valid) { skipped++; continue; }

            const match = state.masterList.find(m =>
                m.status &&
                norm(m.prodLine)===norm(pl) && norm(m.type)===norm(pt) &&
                norm(m.profile)===norm(p)   && norm(m.color)===norm(c) &&
                norm(m.length)===norm(l)
            );
            if (!match) { skipped++; continue; }

            const dup = existing.find(cfg =>
                norm(cfg.prodLine)===norm(pl) && norm(cfg.type)===norm(pt) &&
                norm(cfg.profile)===norm(p)   && norm(cfg.color)===norm(c) &&
                norm(cfg.length)===norm(l)    && cfg.status
            );
            if (dup) { skipped++; continue; }

            const nid = Date.now() + i;
            newIds.push(nid);
            existing.push({
                id: nid, slNo: existing.length + 1,
                prodLine:match.prodLine, type:match.type, profile:match.profile,
                color:match.color, length:match.length, sku:match.sku, desc:match.desc,
                ...nums, status:true, createdBy:CURRENT_USER,
                history:[{ date:now.full, action:'Imported', user:CURRENT_USER, details:'Bulk Limits spec spreadsheet upload' }]
            });
            added++;
        }

        newIds.forEach(id => state.stNewBatch.add(id));
        state.stPage = 1;
        renderStTable();
        showToast(`Ski-Tipping metrics parsed. Added: ${added}, Skipped: ${skipped}`, added > 0 ? 'success' : 'error');
        event.target.value = '';
    };
    reader.readAsText(file);
}

// ========================================================
// EMBOSSING OPERATIONAL QC ACTIONS
// ========================================================
function buildDashSelect(id, field, filters, selectedVal, rowId) {
    const embConfigs = (state.labConfigs['Embossing'] || []).filter(c => c.status);
    const useConfigs = embConfigs.length > 0;
    let source = useConfigs ? embConfigs : state.masterList.filter(m => m.status);

    if (filters.pl) source = source.filter(c => c.prodLine === filters.pl);
    if (filters.pt) source = source.filter(c => c.type === filters.pt);
    if (filters.p)  source = source.filter(c => c.profile === filters.p);
    if (filters.c)  source = source.filter(c => c.color === filters.c);
    const fieldMap = { pl:'prodLine', pt:'type', p:'profile', c:'color', l:'length' };
    const key = fieldMap[field];
    const vals = [...new Set(source.map(c => c[key]))].sort();
    let html = `<select class="form-input" id="${id}" onchange="handleDashDropdownChange('${rowId}','${field}',this.value)"><option value="">Select</option>`;
    vals.forEach(v => { html += `<option value="${v}" ${v===selectedVal?'selected':''}>${v}</option>`; });
    return html + '</select>';
}

function handleDashDropdownChange(rowId, field, value) {
    const sel = rowId === 'new' ? state.newDashSel : state.editDashSel;
    if (rowId === 'new') {
        const lineEl = document.getElementById('d-line');
        if (lineEl) state.newDashSel.line = lineEl.value;
        const m1El = document.getElementById('d-m1'); if (m1El) state.newDashSel._m1 = m1El.value;
        const m2El = document.getElementById('d-m2'); if (m2El) state.newDashSel._m2 = m2El.value;
        const m3El = document.getElementById('d-m3'); if (m3El) state.newDashSel._m3 = m3El.value;
    }
    const order = ['pl','pt','p','c','l'];
    const idx = order.indexOf(field);
    sel[field] = value;
    for (let i = idx+1; i < order.length; i++) sel[order[i]] = '';
    renderDashTable();
    if (rowId === 'new') {
        const m1El = document.getElementById('d-m1'); if (m1El && state.newDashSel._m1) m1El.value = state.newDashSel._m1;
        const m2El = document.getElementById('d-m2'); if (m2El && state.newDashSel._m2) m2El.value = state.newDashSel._m2;
        const m3El = document.getElementById('d-m3'); if (m3El && state.newDashSel._m3) m3El.value = state.newDashSel._m3;
        if (state.newDashSel._m1 || state.newDashSel._m2 || state.newDashSel._m3) calcAvg('new');
    }
}

function calcAvg(rowId) {
    if (rowId === 'new') {
        const m1 = parseFloat(document.getElementById('d-m1')?.value)||0;
        const m2 = parseFloat(document.getElementById('d-m2')?.value)||0;
        const m3 = parseFloat(document.getElementById('d-m3')?.value)||0;
        const avg = ((m1+m2+m3)/3).toFixed(4);
        const hid = document.getElementById('d-avg-hid'); if (hid) hid.value = avg;
        const disp = document.getElementById('d-avg-disp');
        if (disp) {
            disp.innerText = avg;
            const s = state.newDashSel;
            const cfg = (state.labConfigs['Embossing']||[]).find(c => c.status&&c.prodLine===s.pl&&c.type===s.pt&&c.profile===s.p&&c.color===s.c&&c.length===s.l);
            if (cfg) {
                const num = parseFloat(avg);
                disp.className = (num >= cfg.min && num <= cfg.max) ? 'avg-pass' : 'avg-fail';
            } else {
                disp.className = 'avg-neutral';
            }
        }
    } else {
        const m1 = parseFloat(document.getElementById('ed-m1')?.value)||0;
        const m2 = parseFloat(document.getElementById('ed-m2')?.value)||0;
        const m3 = parseFloat(document.getElementById('ed-m3')?.value)||0;
        const avg = ((m1+m2+m3)/3).toFixed(4);
        const el = document.getElementById(`ed-avg-${rowId}`);
        if (el) {
            el.innerText = avg;
            const row = state.embossingData.find(r => r.id===rowId);
            if (row && row.snapMin !== null) {
                const num = parseFloat(avg);
                el.className = (num >= row.snapMin && num <= row.snapMax) ? 'avg-pass' : 'avg-fail';
            }
        }
    }
}

let openDashFilterId = null;
function openDashFilter(event, field, iconEl) {
    event.stopPropagation();
    const ddId = 'dash-cfd-' + field;
    const dd = document.getElementById(ddId);
    if (!dd) return;
    if (openDashFilterId && openDashFilterId !== ddId) {
        const old = document.getElementById(openDashFilterId);
        if (old) old.classList.remove('show');
    }
    if (dd.classList.contains('show')) { dd.classList.remove('show'); openDashFilterId = null; return; }
    const vals = [...new Set(state.embossingData.map(r => String(r[field]||'')))].filter(v=>v!=='').sort();
    const current = state.dashFilters[field];
    let ddHtml = `<div class="col-filter-item clear-all" onclick="clearDashFilter('${field}')"><i class="fas fa-times" style="font-size:10px;"></i> All / Clear</div>`;
    vals.forEach(v => { ddHtml += `<div class="col-filter-item ${current===v?'selected':''}" onclick="applyDashFilter('${field}','${v.replace(/'/g,"\'")}' )">${v}</div>`; });
    dd.innerHTML = ddHtml;
    dd.classList.add('show');
    openDashFilterId = ddId;
}
function applyDashFilter(field, value) {
    state.dashFilters[field] = value;
    const icon = document.getElementById('dash-fi-' + field);
    if (icon) icon.classList.add('active-filter');
    const dd = document.getElementById('dash-cfd-' + field);
    if (dd) dd.classList.remove('show');
    openDashFilterId = null; state.dashPage = 1; renderDashTable();
    renderSPCControlChart();
}
function clearDashFilter(field) {
    delete state.dashFilters[field];
    const icon = document.getElementById('dash-fi-' + field);
    if (icon) icon.classList.remove('active-filter');
    const dd = document.getElementById('dash-cfd-' + field);
    if (dd) dd.classList.remove('show');
    openDashFilterId = null; state.dashPage = 1; renderDashTable();
    renderSPCControlChart();
}
function applyDashDateFilter() {
    state.dashStartDate = document.getElementById('emb-start-date').value;
    state.dashEndDate   = document.getElementById('emb-end-date').value;
    state.dashPage = 1; renderDashTable();
    renderSPCControlChart();
}
function getFilteredDash() {
    return state.embossingData.filter(row => {
        const colPass = Object.entries(state.dashFilters).every(([field, val]) =>
            !val || String(row[field]||'') === val
        );
        let datePass = true;
        if (state.dashStartDate || state.dashEndDate) {
            const iso = row.createdOn || '';
            if (state.dashStartDate && iso < state.dashStartDate) datePass = false;
            if (state.dashEndDate   && iso > state.dashEndDate)   datePass = false;
        }
        return colPass && datePass;
    });
}
function gotoDashPage(p) { state.dashPage = p; renderDashTable(); }

// ========================================================
// ========================================================
function renderDashTable() {
    const tbody = document.getElementById('embossing-table-body');
    if (!tbody) return;
    tbody.innerHTML = '';

    if (state.isCreatingDash) {
        const s = state.newDashSel;
        const lines = ['Line A','Line B','Line C','Line D'];
        let lineOpts = `<option value="">Select</option>` + lines.map(l => `<option value="${l}" ${l===s.line?'selected':''}>${l}</option>`).join('');
        const tr = document.createElement('tr');
        tr.className = 'new-row-tr';
        tr.innerHTML = `
            <td>
                <button class="btn-icon-only" onclick="saveDashRow()" title="Save" style="color:white;font-size:16px;"><i class="fas fa-save"></i></button>
            </td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;font-style:italic;">Auto</td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;font-style:italic;">Auto</td>
            <td><select class="form-input" id="d-line" onchange="state.newDashSel.line=this.value">${lineOpts}</select></td>
            <td>${buildDashSelect('d-pl','pl',{},s.pl,'new')}</td>
            <td>${buildDashSelect('d-pt','pt',{pl:s.pl},s.pt,'new')}</td>
            <td>${buildDashSelect('d-p','p',{pl:s.pl,pt:s.pt},s.p,'new')}</td>
            <td>${buildDashSelect('d-c','c',{pl:s.pl,pt:s.pt,p:s.p},s.c,'new')}</td>
            <td>${buildDashSelect('d-l','l',{pl:s.pl,pt:s.pt,p:s.p,c:s.c},s.l,'new')}</td>
            <td><input type="number" class="form-input" id="d-m1" placeholder="Measure" style="width:70px;" oninput="calcAvg('new')"></td>
            <td><input type="number" class="form-input" id="d-m2" placeholder="Measure" style="width:70px;" oninput="calcAvg('new')"></td>
            <td><input type="number" class="form-input" id="d-m3" placeholder="Measure" style="width:70px;" oninput="calcAvg('new')"></td>
            <td><span id="d-avg-disp" class="avg-neutral">—</span><input type="hidden" id="d-avg-hid"></td>
            <td style="color:rgba(255,255,255,0.85);font-size:11px;">${CURRENT_USER}</td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;font-style:italic;">Auto</td>
            <td style="color:rgba(255,255,255,0.7);">—</td>
        `;
        tbody.appendChild(tr);
    }

    const filtered = getFilteredDash();
    const total = filtered.length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (state.dashPage > totalPages) state.dashPage = totalPages;
    const start = (state.dashPage - 1) * PAGE_SIZE;
    const pageData = filtered.slice(start, start + PAGE_SIZE);

    pageData.forEach(row => {
        const tr = document.createElement('tr');
        const isEditing = state.editingDashId === row.id;
        let avgClass = '';
        if (row.snapMin !== null && row.snapMax !== null) {
            avgClass = (row.avg >= row.snapMin && row.avg <= row.snapMax) ? 'cell-pass' : 'cell-fail';
        }
        if (isEditing) {
            tr.className = 'edit-row-tr';
            const s = state.editDashSel;
            const lines = ['Line A','Line B','Line C','Line D'];
            let lineOpts = lines.map(l => `<option value="${l}" ${l===row.line?'selected':''}>${l}</option>`).join('');
            tr.innerHTML = `
                <td>
                    <button class="btn-icon-only" onclick="updateDashRow(${row.id})" title="Save"><i class="fas fa-check" style="color:var(--success-color)"></i></button>
                    <button class="btn-icon-only" onclick="cancelEditDash()" title="Cancel"><i class="fas fa-times"></i></button>
                </td>
                <td>${row.date}</td><td>${row.time}</td>
                <td><select class="form-input" id="ed-line" style="width:80px;">${lineOpts}</select></td>
                <td>${buildDashSelect('ed-pl','pl',{},s.pl,row.id)}</td>
                <td>${buildDashSelect('ed-pt','pt',{pl:s.pl},s.pt,row.id)}</td>
                <td>${buildDashSelect('ed-p','p',{pl:s.pl,pt:s.pt},s.p,row.id)}</td>
                <td>${buildDashSelect('ed-c','c',{pl:s.pl,pt:s.pt,p:s.p},s.c,row.id)}</td>
                <td>${buildDashSelect('ed-l','l',{pl:s.pl,pt:s.pt,p:s.p,c:s.c},s.l,row.id)}</td>
                <td><input type="number" class="form-input" id="ed-m1" value="${row.m1}" oninput="calcAvg(${row.id})" style="width:70px;"></td>
                <td><input type="number" class="form-input" id="ed-m2" value="${row.m2}" oninput="calcAvg(${row.id})" style="width:70px;"></td>
                <td><input type="number" class="form-input" id="ed-m3" value="${row.m3}" oninput="calcAvg(${row.id})" style="width:70px;"></td>
                <td><span id="ed-avg-${row.id}" class="${avgClass}">${row.avg}</span></td>
                <td>${row.createdBy}</td>
                <td style="white-space:nowrap;">${row.createdOn||row.date}</td>
                <td style="white-space:nowrap;">${row.modifiedOn||'—'}</td>
            `;
        } else {
            tr.innerHTML = `
                <td>
                    <button class="btn-icon-only" onclick="startEditDash(${row.id})" title="Edit"><i class="fas fa-pencil-alt"></i></button>
                    <button class="btn-icon-only" onclick="openHistPanelDash(${row.id})" title="History"><i class="fas fa-history"></i></button>
                    <button class="btn-icon-only" style="color:#ccc;" onmouseover="this.style.color='var(--danger-color)'" onmouseout="this.style.color='#ccc'" onclick="deleteDashRow(${row.id})" title="Delete"><i class="fas fa-trash"></i></button>
                </td>
                <td>${row.date}</td><td>${row.time}</td>
                <td>${row.line}</td><td>${row.prodLine}</td><td>${row.profileType}</td>
                <td>${row.profile}</td><td>${row.color}</td><td>${row.length}</td>
                <td>${row.m1}</td><td>${row.m2}</td><td>${row.m3}</td>
                <td class="${avgClass}">${row.avg}</td>
                <td>${row.createdBy}</td>
                <td style="white-space:nowrap;">${row.createdOn||row.date}</td>
                <td style="white-space:nowrap;">${row.modifiedOn||'—'}</td>
            `;
        }
        tbody.appendChild(tr);
    });

    const recEl = document.getElementById('dash-rec-count');
    if (recEl) recEl.innerText = `${total} Record${total!==1?'s':''}`;
    const pagEl = document.getElementById('dash-pagination');
    if (pagEl) {
        const firstBtn = `<button class="page-btn txt" ${state.dashPage===1?'disabled':''} onclick="gotoDashPage(1)">First</button>`;
        const prevBtn  = `<button class="page-btn" ${state.dashPage===1?'disabled':''} onclick="gotoDashPage(${state.dashPage-1})">&lsaquo;</button>`;
        let pages = '';
        for (let i = Math.max(1,state.dashPage-2); i <= Math.min(totalPages,state.dashPage+2); i++) {
            pages += `<button class="page-btn ${i===state.dashPage?'active':''}" onclick="gotoDashPage(${i})">${i}</button>`;
        }
        const nextBtn = `<button class="page-btn" ${state.dashPage===totalPages?'disabled':''} onclick="gotoDashPage(${state.dashPage+1})">&rsaquo;</button>`;
        const lastBtn = `<button class="page-btn txt" ${state.dashPage===totalPages?'disabled':''} onclick="gotoDashPage(${totalPages})">Last</button>`;
        pagEl.innerHTML = firstBtn + prevBtn + pages + nextBtn + lastBtn;
    }
}

function startAddDashboardRow() {
    if (state.editingDashId) cancelEditDash();
    state.isCreatingDash = true;
    state.newDashSel = { pl:'', pt:'', p:'', c:'', l:'', line:'' };
    renderDashTable();
}
function cancelDashRow() { state.newDashSel = { pl:'', pt:'', p:'', c:'', l:'', line:'' }; renderDashTable(); }
function startEditDash(id) {
    state.editingDashId = id;
    const row = state.embossingData.find(r => r.id===id);
    state.editDashSel = { pl:row.prodLine, pt:row.profileType, p:row.profile, c:row.color, l:row.length };
    renderDashTable();
}
function cancelEditDash() { state.editingDashId = null; renderDashTable(); }

// Compliance modification: customConfirm replaces blocking window.confirm()
function deleteDashRow(id) {
    customConfirm('Delete this operational embossing quality measurement log permanently?', () => {
        state.embossingData = state.embossingData.filter(d => d.id !== id);
        renderDashTable();
        renderSPCControlChart();
        showToast('Quality log deleted', 'success');
    });
}

function saveDashRow() {
    const s = state.newDashSel;
    const line = document.getElementById('d-line').value;
    const m1 = parseFloat(document.getElementById('d-m1').value);
    const m2 = parseFloat(document.getElementById('d-m2').value);
    const m3 = parseFloat(document.getElementById('d-m3').value);
    if (!line||!s.pl||!s.pt||!s.p||!s.c||!s.l) { showToast('Complete all selection fields', 'error'); return; }
    if (isNaN(m1)||isNaN(m2)||isNaN(m3)) { showToast('Provide physical measurement parameters', 'error'); return; }
    const avg = parseFloat(((m1+m2+m3)/3).toFixed(4));
    
    // Format date as DD-Mon-YYYY
    const dObj = new Date();
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const formattedDate = `${String(dObj.getDate()).padStart(2,'0')}-${months[dObj.getMonth()]}-${dObj.getFullYear()}`;
    const formattedTime = dObj.toTimeString().slice(0,5);
    
    const cfg = (state.labConfigs['Embossing']||[]).find(c => c.prodLine===s.pl&&c.type===s.pt&&c.profile===s.p&&c.color===s.c&&c.length===s.l);
    const isoDate = getISODate();
    
    state.embossingData.unshift({ 
        id: Date.now(), 
        date: formattedDate, 
        time: formattedTime, 
        line, 
        prodLine: s.pl, 
        profileType: s.pt, 
        profile: s.p, 
        color: s.c, 
        length: s.l, 
        m1, m2, m3, avg, 
        createdBy: CURRENT_USER, 
        createdOn: isoDate, 
        modifiedOn: null, 
        snapMin: cfg ? cfg.min : null, 
        snapMax: cfg ? cfg.max : null, 
        history: [{ date: getNow().full, action: 'Created', user: CURRENT_USER, details: 'Operational testing log recorded' }] 
    });
    
    state.newDashSel = { pl:'', pt:'', p:'', c:'', l:'', line:'' };
    state.isCreatingDash = true;
    renderDashTable();
    renderSPCControlChart();
    showToast('Quality entry successfully logged', 'success');
}

function updateDashRow(id) {
    const row = state.embossingData.find(r => r.id===id);
    const s = state.editDashSel;
    row.line = document.getElementById('ed-line').value;
    row.prodLine = s.pl; row.profileType = s.pt; row.profile = s.p; row.color = s.c; row.length = s.l;
    row.m1 = parseFloat(document.getElementById('ed-m1').value);
    row.m2 = parseFloat(document.getElementById('ed-m2').value);
    row.m3 = parseFloat(document.getElementById('ed-m3').value);
    row.avg = parseFloat(((row.m1+row.m2+row.m3)/3).toFixed(4));
    const cfg = (state.labConfigs['Embossing']||[]).find(c => c.prodLine===s.pl&&c.type===s.pt&&c.profile===s.p&&c.color===s.c&&c.length===s.l);
    if (cfg) { row.snapMin = cfg.min; row.snapMax = cfg.max; }
    row.modifiedOn = getISODate();
    const nowFull = getNow().full;
    if (!row.history) row.history = [];
    row.history.unshift({ date:nowFull, action:'Updated', user:CURRENT_USER, details:`Metrics adjusted: M1:${row.m1}, M2:${row.m2}, M3:${row.m3}` });
    state.editingDashId = null;
    renderDashTable();
    renderSPCControlChart();
    showToast('QC Log modification complete', 'success');
}

// ========================================================
// SKI-TIPPING OPERATIONAL QC ACTIONS
// ========================================================
function buildStDashSelect(id, field, filters, selectedVal, rowId) {
    const stConfigs = (state.labConfigs['Ski-Tipping'] || []).filter(c => c.status);
    const useST = stConfigs.length > 0;
    let source = useST ? stConfigs : state.masterList.filter(m => m.status);
    if (filters.pl) source = source.filter(c => c.prodLine === filters.pl);
    if (filters.pt) source = source.filter(c => c.type === filters.pt);
    if (filters.p)  source = source.filter(c => c.profile === filters.p);
    if (filters.c)  source = source.filter(c => c.color === filters.c);
    const fieldMap = { pl:'prodLine', pt:'type', p:'profile', c:'color', l:'length' };
    const key = fieldMap[field];
    const vals = [...new Set(source.map(c => c[key]))].sort();
    let html = `<select class="form-input" id="${id}" onchange="handleStDashDropdownChange('${rowId}','${field}',this.value)"><option value="">Select</option>`;
    vals.forEach(v => { html += `<option value="${v}" ${v===selectedVal?'selected':''}>${v}</option>`; });
    html += '</select>';
    return html;
}

function handleStDashDropdownChange(rowId, field, value) {
    const sel = rowId === 'new' ? state.stDashNewSel : state.editStDashSel;
    const order = ['pl','pt','p','c','l'];
    const idx = order.indexOf(field);
    sel[field] = value;
    for (let i = idx+1; i < order.length; i++) sel[order[i]] = '';
    if (rowId === 'new' && sel.pl && sel.pt && sel.p && sel.c && sel.l) {
        const match = state.masterList.find(m => m.prodLine===sel.pl&&m.type===sel.pt&&m.profile===sel.p&&m.color===sel.c&&m.length===sel.l);
        state._stDashAutoSku = match ? match.sku : '';
    } else if (rowId === 'new') {
        state._stDashAutoSku = '';
    }
    if (rowId === 'new') {
        state._stDashNewLine    = document.getElementById('std-line')?.value    || state._stDashNewLine || '';
        state._stDashNewShift   = document.getElementById('std-shift')?.value   || '';
        state._stDashNewWo      = document.getElementById('std-wo')?.value      || '';
        state._stDashNewBundle  = document.getElementById('std-bundle')?.value  || '';
        state._stDashNewBoard   = document.getElementById('std-board')?.value   || '';
        state._stDashNewComment = document.getElementById('std-comment')?.value || '';
        state._stDashNewMeasures = {};
        ['stl','mhl','mhls','dml','stt','mht','mhts','dmt'].forEach(f => {
            state._stDashNewMeasures[f] = document.getElementById('std-'+f)?.value || '';
        });
    }
    renderStDashTable();
    if (rowId === 'new') {
        const setVal = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };
        setVal('std-line',    state._stDashNewLine);
        setVal('std-shift',   state._stDashNewShift);
        setVal('std-wo',      state._stDashNewWo);
        setVal('std-bundle',  state._stDashNewBundle);
        setVal('std-board',   state._stDashNewBoard);
        setVal('std-comment', state._stDashNewComment);
        if (state._stDashNewMeasures) {
            ['stl','mhl','mhls','dml','stt','mht','mhts','dmt'].forEach(f => {
                setVal('std-'+f, state._stDashNewMeasures[f]);
            });
            calcStDashBadgesLive();
        }
    }
}

function calcStDashBadgesLive() {
    const s = state.stDashNewSel;
    const cfg = (state.labConfigs['Ski-Tipping']||[]).find(c =>
        c.status && c.prodLine===s.pl && c.type===s.pt && c.profile===s.p && c.color===s.c && c.length===s.l
    );
    const cfgKeys = ['stl','mhl','mhls','dml','stt','mht','mhts','dmt'];
    cfgKeys.forEach(f => {
        const el = document.getElementById('std-' + f);
        if (!el) return;
        el.classList.remove('input-pass', 'input-fail');
        const specVal = cfg ? cfg[f] : undefined;
        const val = parseFloat(el.value);
        if (specVal !== undefined && !isNaN(val) && el.value !== '') {
            el.classList.add(val <= specVal ? 'input-pass' : 'input-fail');
        }
    });
}
function getStDashBadge(val, specVal) {
    if (specVal === undefined || specVal === null || val === '' || isNaN(parseFloat(val))) return `<span style="color:#888;">—</span>`;
    const pass = parseFloat(val) <= parseFloat(specVal);
    return `<span class="${pass ? 'cell-pass' : 'cell-fail'}">${val}</span>`;
}

function getFilteredStDash() {
    return state.stDashData.filter(row => {
        const colPass = Object.entries(state.stDashFilters).every(([field, val]) => !val || String(row[field]||'') === val);
        let datePass = true;
        if (state.stDashStartDate || state.stDashEndDate) {
            const iso = row.createdOn || '';
            if (state.stDashStartDate && iso < state.stDashStartDate) datePass = false;
            if (state.stDashEndDate   && iso > state.stDashEndDate)   datePass = false;
        }
        return colPass && datePass;
    });
}

// ========================================================
// ========================================================
let openStDashFilterId = null;
function openStDashFilter(event, field, iconEl) {
    event.stopPropagation();
    const ddId = 'std-cfd-' + field;
    const dd = document.getElementById(ddId);
    if (!dd) return;
    if (openStDashFilterId && openStDashFilterId !== ddId) {
        const old = document.getElementById(openStDashFilterId);
        if (old) old.classList.remove('show');
    }
    if (dd.classList.contains('show')) { dd.classList.remove('show'); openStDashFilterId = null; return; }
    const vals = [...new Set(state.stDashData.map(r => String(r[field]||'')))].filter(v=>v!=='').sort();
    const current = state.stDashFilters[field];
    let ddHtml = `<div class="col-filter-item clear-all" onclick="clearStDashFilter('${field}')"><i class="fas fa-times" style="font-size:10px;"></i> All / Clear</div>`;
    vals.forEach(v => { ddHtml += `<div class="col-filter-item ${current===v?'selected':''}" onclick="applyStDashFilter('${field}','${v.replace(/'/g,"\'")}' )">${v}</div>`; });
    dd.innerHTML = ddHtml; dd.classList.add('show'); openStDashFilterId = ddId;
}
function applyStDashFilter(field, value) {
    state.stDashFilters[field] = value;
    const icon = document.getElementById('std-fi-' + field);
    if (icon) icon.classList.add('active-filter');
    const dd = document.getElementById('std-cfd-' + field);
    if (dd) dd.classList.remove('show');
    openStDashFilterId = null; state.stDashPage = 1; renderStDashTable();
}
function clearStDashFilter(field) {
    delete state.stDashFilters[field];
    const icon = document.getElementById('std-fi-' + field);
    if (icon) icon.classList.remove('active-filter');
    const dd = document.getElementById('std-cfd-' + field);
    if (dd) dd.classList.remove('show');
    openStDashFilterId = null; state.stDashPage = 1; renderStDashTable();
}
function applyStDashDateFilter() {
    state.stDashStartDate = document.getElementById('std-start-date').value;
    state.stDashEndDate   = document.getElementById('std-end-date').value;
    state.stDashPage = 1; renderStDashTable();
}
function gotoStDashPage(p) { state.stDashPage = p; renderStDashTable(); }

function renderStDashTable() {
    const tbody = document.getElementById('st-dash-body');
    if (!tbody) return;
    tbody.innerHTML = '';

    if (state.isCreatingStDash) {
        const s = state.stDashNewSel;
        const autoSku = state._stDashAutoSku || '';
        const lines = ['Line A','Line B','Line C','Line D','301','302','303'];
        const tr = document.createElement('tr');
        tr.className = 'new-row-tr';
        tr.innerHTML = `
            <td>
                <button class="btn-icon-only" onclick="saveStDashRow()" title="Save" style="color:white;font-size:16px;"><i class="fas fa-save"></i></button>
            </td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;font-style:italic;">Auto</td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;font-style:italic;">Auto</td>
            <td><select class="form-input" id="std-line" style="width:75px;"><option value="">Select</option>${lines.map(l=>`<option value="${l}">${l}</option>`).join('')}</select></td>
            <td>${buildStDashSelect('std-pl','pl',{},s.pl,'new')}</td>
            <td>${buildStDashSelect('std-pt','pt',{pl:s.pl},s.pt,'new')}</td>
            <td>${buildStDashSelect('std-p','p',{pl:s.pl,pt:s.pt},s.p,'new')}</td>
            <td>${buildStDashSelect('std-c','c',{pl:s.pl,pt:s.pt,p:s.p},s.c,'new')}</td>
            <td>${buildStDashSelect('std-l','l',{pl:s.pl,pt:s.pt,p:s.p,c:s.c},s.l,'new')}</td>
            <td><input class="form-input" id="std-sku" value="${autoSku}" readonly placeholder="Auto" style="background:rgba(255,255,255,0.15);width:100px;"></td>
            <td><input class="form-input" id="std-shift" placeholder="Shift" style="width:78px;"></td>
            <td><input class="form-input" id="std-wo" placeholder="WO" style="width:65px;"></td>
            <td><input class="form-input" id="std-bundle" placeholder="Bundle" style="width:70px;"></td>
            <td><input class="form-input" id="std-board" placeholder="Board" style="width:70px;"></td>
            <td style="border-left:2px solid rgba(255,255,255,0.3);"><input type="number" class="form-input" id="std-stl" placeholder="Val" oninput="calcStDashBadgesLive()" style="width:75px;"></td>
            <td><input type="number" class="form-input" id="std-mhl" placeholder="Val" oninput="calcStDashBadgesLive()" style="width:75px;"></td>
            <td style="border-left:1px solid rgba(255,255,255,0.2);"><input type="number" class="form-input" id="std-mhls" placeholder="Val" oninput="calcStDashBadgesLive()" style="width:75px;"></td>
            <td><input type="number" class="form-input" id="std-dml" placeholder="Val" oninput="calcStDashBadgesLive()" style="width:90px;"></td>
            <td style="border-left:2px solid rgba(255,255,255,0.3);"><input type="number" class="form-input" id="std-stt" placeholder="Val" oninput="calcStDashBadgesLive()" style="width:75px;"></td>
            <td><input type="number" class="form-input" id="std-mht" placeholder="Val" oninput="calcStDashBadgesLive()" style="width:75px;"></td>
            <td style="border-left:1px solid rgba(255,255,255,0.2);"><input type="number" class="form-input" id="std-mhts" placeholder="Val" oninput="calcStDashBadgesLive()" style="width:75px;"></td>
            <td><input type="number" class="form-input" id="std-dmt" placeholder="Val" oninput="calcStDashBadgesLive()" style="width:90px;"></td>
            <td><input class="form-input" id="std-comment" placeholder="Comment" style="width:95px;"></td>
            <td style="color:rgba(255,255,255,0.85);font-size:11px;">${CURRENT_USER}</td>
            <td style="color:rgba(255,255,255,0.7);font-size:11px;font-style:italic;">Auto</td>
            <td style="color:rgba(255,255,255,0.7);">—</td>
        `;
        tbody.appendChild(tr);
    }

    const filtered = getFilteredStDash();
    const total = filtered.length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    if (state.stDashPage > totalPages) state.stDashPage = totalPages;
    const start = (state.stDashPage - 1) * PAGE_SIZE;
    const pageData = filtered.slice(start, start + PAGE_SIZE);

    pageData.forEach(row => {
        const tr = document.createElement('tr');
        const isEditing = state.editingStDashId === row.id;
        const cfg = (state.labConfigs['Ski-Tipping']||[]).find(c =>
            c.status && c.prodLine===row.prodLine && c.type===row.profileType &&
            c.profile===row.profile && c.color===row.color && c.length===row.length
        );
        if (isEditing) {
            tr.className = 'edit-row-tr';
            const s = state.editStDashSel;
            const lines = ['Line A','Line B','Line C','Line D','301','302','303'];
            const lineOpts = lines.map(l=>`<option value="${l}" ${l===row.line?'selected':''}>${l}</option>`).join('');
            tr.innerHTML = `
                <td>
                    <button class="btn-icon-only" onclick="updateStDashRow(${row.id})" title="Update"><i class="fas fa-check" style="color:var(--success-color)"></i></button>
                    <button class="btn-icon-only" onclick="cancelEditStDash()" title="Cancel"><i class="fas fa-times"></i></button>
                </td>
                <td>${row.date}</td><td>${row.time}</td>
                <td><select class="form-input" id="ed-std-line" style="width:75px;">${lineOpts}</select></td>
                <td>${buildStDashSelect('ed-std-pl','pl',{},s.pl,row.id)}</td>
                <td>${buildStDashSelect('ed-std-pt','pt',{pl:s.pl},s.pt,row.id)}</td>
                <td>${buildStDashSelect('ed-std-p','p',{pl:s.pl,pt:s.pt},s.p,row.id)}</td>
                <td>${buildStDashSelect('ed-std-c','c',{pl:s.pl,pt:s.pt,p:s.p},s.c,row.id)}</td>
                <td>${buildStDashSelect('ed-std-l','l',{pl:s.pl,pt:s.pt,p:s.p,c:s.c},s.l,row.id)}</td>
                <td><input class="form-input" value="${row.sku}" readonly style="background:#f5f5f5;width:100px;"></td>
                <td><input class="form-input" id="ed-std-shift" value="${row.shiftCode}" style="width:78px;"></td>
                <td><input class="form-input" id="ed-std-wo" value="${row.wo}" style="width:65px;"></td>
                <td><input class="form-input" id="ed-std-bundle" value="${row.bundle}" style="width:70px;"></td>
                <td><input class="form-input" id="ed-std-board" value="${row.board}" style="width:70px;"></td>
                <td style="border-left:2px solid #e0e0e0;"><input type="number" class="form-input" id="ed-std-stl" value="${row.stl}" style="width:75px;"></td>
                <td><input type="number" class="form-input" id="ed-std-mhl" value="${row.mhl}" style="width:75px;"></td>
                <td style="border-left:1px solid #eee;"><input type="number" class="form-input" id="ed-std-mhls" value="${row.mhls}" style="width:75px;"></td>
                <td><input type="number" class="form-input" id="ed-std-dml" value="${row.dml}" style="width:90px;"></td>
                <td style="border-left:2px solid #e0e0e0;"><input type="number" class="form-input" id="ed-std-stt" value="${row.stt}" style="width:75px;"></td>
                <td><input type="number" class="form-input" id="ed-std-mht" value="${row.mht}" style="width:75px;"></td>
                <td style="border-left:1px solid #eee;"><input type="number" class="form-input" id="ed-std-mhts" value="${row.mhts}" style="width:75px;"></td>
                <td><input type="number" class="form-input" id="ed-std-dmt" value="${row.dmt}" style="width:90px;"></td>
                <td><input class="form-input" id="ed-std-comment" value="${row.comment||''}" style="width:95px;"></td>
                <td>${row.createdBy}</td>
                <td>${row.createdOn||row.date}</td>
                <td>${row.modifiedOn||'—'}</td>
            `;
        } else {
            tr.innerHTML = `
                <td>
                    <button class="btn-icon-only" onclick="startEditStDash(${row.id})" title="Edit"><i class="fas fa-pencil-alt"></i></button>
                    <button class="btn-icon-only" onclick="openHistPanelStDash(${row.id})" title="History"><i class="fas fa-history"></i></button>
                    <button class="btn-icon-only" style="color:#ccc;" onmouseover="this.style.color='var(--danger-color)'" onmouseout="this.style.color='#ccc'" onclick="deleteStDashRow(${row.id})" title="Delete"><i class="fas fa-trash"></i></button>
                </td>
                <td>${row.date}</td><td>${row.time}</td>
                <td>${row.line}</td><td>${row.prodLine}</td><td>${row.profileType}</td>
                <td>${row.profile}</td><td>${row.color}</td><td>${row.length}</td>
                <td>${row.sku}</td>
                <td>${row.shiftCode}</td><td>${row.wo}</td>
                <td>${row.bundle}</td><td>${row.board}</td>
                <td style="border-left:2px solid #e0e0e0;">${getStDashBadge(row.stl,  row.snapStl  ?? cfg?.stl)}</td>
                <td>${getStDashBadge(row.mhl,  row.snapMhl  ?? cfg?.mhl)}</td>
                <td style="border-left:1px solid #eee;">${getStDashBadge(row.mhls, row.snapMhls ?? cfg?.mhls)}</td>
                <td>${getStDashBadge(row.dml,  row.snapDml  ?? cfg?.dml)}</td>
                <td style="border-left:2px solid #e0e0e0;">${getStDashBadge(row.stt,  row.snapStt  ?? cfg?.stt)}</td>
                <td>${getStDashBadge(row.mht,  row.snapMht  ?? cfg?.mht)}</td>
                <td style="border-left:1px solid #eee;">${getStDashBadge(row.mhts, row.snapMhts ?? cfg?.mhts)}</td>
                <td>${getStDashBadge(row.dmt,  row.snapDmt  ?? cfg?.dmt)}</td>
                <td>${row.comment||''}</td>
                <td>${row.createdBy}</td>
                <td style="white-space:nowrap;">${row.createdOn||row.date}</td>
                <td style="white-space:nowrap;">${row.modifiedOn||'—'}</td>
            `;
        }
        tbody.appendChild(tr);
    });

    const recEl = document.getElementById('std-rec-count');
    if (recEl) recEl.innerText = `${total} Record${total!==1?'s':''}`;
    const pagEl = document.getElementById('std-pagination');
    if (pagEl) {
        const totalPg = Math.max(1, Math.ceil(total / PAGE_SIZE));
        const firstBtn = `<button class="page-btn txt" ${state.stDashPage===1?'disabled':''} onclick="gotoStDashPage(1)">First</button>`;
        const prevBtn  = `<button class="page-btn" ${state.stDashPage===1?'disabled':''} onclick="gotoStDashPage(${state.stDashPage-1})">&lsaquo;</button>`;
        let pages = '';
        for (let i = Math.max(1,state.stDashPage-2); i <= Math.min(totalPg,state.stDashPage+2); i++) {
            pages += `<button class="page-btn ${i===state.stDashPage?'active':''}" onclick="gotoStDashPage(${i})">${i}</button>`;
        }
        const nextBtn = `<button class="page-btn" ${state.stDashPage===totalPg?'disabled':''} onclick="gotoStDashPage(${state.stDashPage+1})">&rsaquo;</button>`;
        const lastBtn = `<button class="page-btn txt" ${state.stDashPage===totalPg?'disabled':''} onclick="gotoStDashPage(${totalPg})">Last</button>`;
        pagEl.innerHTML = firstBtn + prevBtn + pages + nextBtn + lastBtn;
    }
}

// ========================================================
// ========================================================
function saveStDashRow() {
    const s = state.stDashNewSel;
    const line = document.getElementById('std-line')?.value || state._stDashNewLine || '';
    const shift = document.getElementById('std-shift')?.value?.trim();
    const wo    = document.getElementById('std-wo')?.value?.trim();
    const bundle= document.getElementById('std-bundle')?.value?.trim();
    const board = document.getElementById('std-board')?.value?.trim();
    if (!line||!s.pl||!s.pt||!s.p||!s.c||!s.l) { showToast('Complete all selection fields', 'error'); return; }
    if (!shift||!wo||!bundle||!board) { showToast('Shift, Work Order, Bundle & Board parameters required', 'error'); return; }
    const numFields = ['stl','mhl','mhls','dml','stt','mht','mhts','dmt'];
    const nums = {};
    for (const f of numFields) {
        const v = parseFloat(document.getElementById('std-'+f)?.value);
        if (isNaN(v)) { showToast('Complete all specification inputs with numbers', 'error'); return; }
        nums[f] = v;
    }
    const dObj = new Date();
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const formattedDate = `${String(dObj.getDate()).padStart(2,'0')}-${months[dObj.getMonth()]}-${dObj.getFullYear()}`;
    const formattedTime = dObj.toTimeString().slice(0,5);
    const isoDate = getISODate();
    const match = state.masterList.find(m => m.prodLine===s.pl&&m.type===s.pt&&m.profile===s.p&&m.color===s.c&&m.length===s.l);
    const sku = match ? match.sku : (state._stDashAutoSku || '');
    const comment = document.getElementById('std-comment')?.value?.trim() || '';
    
    const cfg = (state.labConfigs['Ski-Tipping']||[]).find(c =>
        c.status && c.prodLine===s.pl && c.type===s.pt && c.profile===s.p && c.color===s.c && c.length===s.l
    );
    const snap = cfg ? { snapStl:cfg.stl, snapMhl:cfg.mhl, snapMhls:cfg.mhls, snapDml:cfg.dml, snapStt:cfg.stt, snapMht:cfg.mht, snapMhts:cfg.mhts, snapDmt:cfg.dmt } : {};
    
    state.stDashData.unshift({
        id: Date.now(), 
        date: formattedDate, 
        time: formattedTime, 
        line,
        prodLine: s.pl, 
        profileType: s.pt, 
        profile: s.p, 
        color: s.c, 
        length: s.l, 
        sku,
        shiftCode: shift, 
        wo, 
        bundle, 
        board, 
        ...nums, 
        comment, 
        ...snap,
        createdBy: CURRENT_USER, 
        createdOn: isoDate, 
        modifiedOn: null,
        history: [{ date: getNow().full, action: 'Created', user: CURRENT_USER, details: 'Ski-Tipping metrics recorded' }]
    });
    
    state.stDashNewSel = { pl:'', pt:'', p:'', c:'', l:'' };
    state._stDashAutoSku = '';
    state._stDashNewLine = ''; state._stDashNewShift = ''; state._stDashNewWo = '';
    state._stDashNewBundle = ''; state._stDashNewBoard = ''; state._stDashNewComment = '';
    state._stDashNewMeasures = {};
    state.isCreatingStDash = true;
    renderStDashTable();
    showToast('Ski-Tipping record saved', 'success');
}

function startEditStDash(id) {
    state.editingStDashId = id;
    const row = state.stDashData.find(r => r.id===id);
    state.editStDashSel = { pl:row.prodLine, pt:row.profileType, p:row.profile, c:row.color, l:row.length };
    renderStDashTable();
}
function cancelEditStDash() { state.editingStDashId = null; renderStDashTable(); }

function updateStDashRow(id) {
    const row = state.stDashData.find(r => r.id===id);
    const s = state.editStDashSel;
    row.line = document.getElementById('ed-std-line')?.value || row.line;
    row.prodLine=s.pl||row.prodLine; row.profileType=s.pt||row.profileType;
    row.profile=s.p||row.profile; row.color=s.c||row.color; row.length=s.l||row.length;
    row.shiftCode = document.getElementById('ed-std-shift')?.value || row.shiftCode;
    row.wo     = document.getElementById('ed-std-wo')?.value || row.wo;
    row.bundle = document.getElementById('ed-std-bundle')?.value || row.bundle;
    row.board  = document.getElementById('ed-std-board')?.value || row.board;
    row.comment= document.getElementById('ed-std-comment')?.value || '';
    const numFields = ['stl','mhl','mhls','dml','stt','mht','mhts','dmt'];
    for (const f of numFields) {
        const v = parseFloat(document.getElementById('ed-std-'+f)?.value);
        if (!isNaN(v)) row[f] = v;
    }
    row.modifiedOn = getISODate();
    
    const updCfg = (state.labConfigs['Ski-Tipping']||[]).find(c =>
        c.status && c.prodLine===row.prodLine && c.type===row.profileType &&
        c.profile===row.profile && c.color===row.color && c.length===row.length
    );
    if (updCfg) {
        row.snapStl=updCfg.stl; row.snapMhl=updCfg.mhl; row.snapMhls=updCfg.mhls; row.snapDml=updCfg.dml;
        row.snapStt=updCfg.stt; row.snapMht=updCfg.mht; row.snapMhts=updCfg.mhts; row.snapDmt=updCfg.dmt;
    }
    if (!row.history) row.history = [];
    row.history.unshift({date:getNow().full, action:'Updated', user:CURRENT_USER, details:`Physical parameters adjusted. WO: ${row.wo}`});
    state.editingStDashId = null;
    renderStDashTable();
    showToast('Ski-Tipping QC Log successfully saved', 'success');
}

// Compliance modification: customConfirm replaces blocking window.confirm()
function deleteStDashRow(id) {
    customConfirm('Delete this operational ski-tipping quality measurement log permanently?', () => {
        state.stDashData = state.stDashData.filter(r => r.id!==id);
        renderStDashTable();
        showToast('QC log entry removed', 'success');
    });
}

function openHistPanelStDash(id) {
    const row = state.stDashData.find(r => r.id===id);
    if (!row) return;
    populateHistPanel(row.history||[], `SkiTipping: ${row.prodLine}/${row.color} Board#${row.board}`);
}

function exportStDashExcel() {
    const filtered = getFilteredStDash();
    let csv = 'Date,Time,Line,Product Line,Profile Type,Profile,Color,Length,SKU,Shift Code,WO,Bundle #,Board #,Ski-Tipping(L),Max Hump CSD(L),Max Hump SSD(L),Dist End Board(L),Ski-Tipping(T),Max Hump CSD(T),Max Hump SSD(T),Dist End Board(T),Comment,Created By,Created On,Modified On\n';
    filtered.forEach(r => {
        csv += `"${r.date}","${r.time}","${r.line}","${r.prodLine}","${r.profileType}","${r.profile}","${r.color}","${r.length}","${r.sku}","${r.shiftCode}","${r.wo}","${r.bundle}","${r.board}",${r.stl},${r.mhl},${r.mhls},${r.dml},${r.stt},${r.mht},${r.mhts},${r.dmt},"${r.comment||''}","${r.createdBy}","${r.createdOn||''}","${r.modifiedOn||''}"\n`;
    });
    downloadCSV(csv, 'SkiTipping_Dashboard_Export.csv');
    showToast('Ski-tipping logs exported', 'success');
}

// ========================================================
// SECURITY ROLES & SESSION CONSOLE PERMISSIONS
// ========================================================
function updatePermissions() {
    state.permissions.new = document.getElementById('perm-new').checked;
    state.permissions.edit = document.getElementById('perm-edit').checked;
    state.permissions.delete = document.getElementById('perm-delete').checked;
    state.configPermissions.new = document.getElementById('perm-config-new').checked;
    state.configPermissions.edit = document.getElementById('perm-config-edit').checked;
    state.configPermissions.delete = document.getElementById('perm-config-delete').checked;
    document.getElementById('add-master-btn').style.display = state.permissions.new ? '' : 'none';
    const cfgBtn = document.getElementById('add-config-btn');
    if (cfgBtn) cfgBtn.style.display = state.configPermissions.new ? '' : 'none';
    renderMasterTable(); renderConfigTable();
}

// ========================================================
// INITIALIZER
// ========================================================
function init() {
    seedDeckingPrototypeData();
    const sel = document.getElementById('lab-selector');
    LAB_OPTIONS.forEach(opt => {
        const el = document.createElement('option'); el.value = opt; el.innerText = opt; sel.appendChild(el);
    });
    renderMasterTable();
    renderDashTable();
    renderSPCControlChart();
}
init();

</script>
</body>
</html>
