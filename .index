        { pl: "Transcend", pt: "1 x 6", p: "Grooved", c: "Spiced Rum", l: "16", sku: "SR010616TG01", desc: "Transcend Grooved 1x6 Board" },
        { pl: "Transcend", pt: "1 x 6", p: "Grooved", c: "Lava Rock", l: "20", sku: "LR010620TG01", desc: "Transcend Grooved 1x6 Board" },
        { pl: "Enhance", pt: "1 x 6", p: "Square Edge", c: "Beach Dune", l: "12", sku: "BD010612EG01", desc: "Enhance Square 1x6 Board" },
        { pl: "Enhance", pt: "1 x 6", p: "Square Edge", c: "Saddle", l: "16", sku: "SD010616EG01", desc: "Enhance Square 1x6 Board" },
        { pl: "Select", pt: "2 x 4", p: "Grooved", c: "Pebble Grey", l: "16", sku: "PG020416SG01", desc: "Select Grooved 2x4 Board" }
